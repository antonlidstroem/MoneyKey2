@page "/lists"
@attribute [Authorize]
@implements IDisposable
@inject ListApiService ListSvc
@inject ToastService   Toast
@inject BudgetState    BudgetState
@inject IJSRuntime     JS
@using MoneyKey.Blazor.Components.Lists
@using MoneyKey.Blazor.Components.Shared

<!-- ═══ Desktop ══════════════════════════════════════════════════════ -->
<div class="desktop-page-wrapper">
    <div class="page-header">
        <span class="page-title">Listor &amp; Anteckningar</span>
        @if (BudgetState.CanEdit)
        {
            <div class="header-actions">
                <BudgetScopeSelector SelectedIds="_scopeIds"
                                     SelectedIdsChanged="ids => _scopeIds = ids"
                                     OnChanged="ReloadAsync" />
                <button class="btn btn-secondary btn-sm" @onclick="() => OpenCreate(false)">
                    <span class="material-icons" style="font-size:.9rem">checklist</span> Ny lista
                </button>
                <button class="btn btn-primary btn-sm" @onclick="() => OpenCreate(true)">
                    <span class="material-icons" style="font-size:.9rem">sticky_note_2</span> Ny anteckning
                </button>
            </div>
        }
    </div>

    <!-- Type tabs -->
    <div style="display:flex;gap:6px;padding:0 24px 12px;flex-wrap:wrap">
        <button class="btn btn-sm @(_tab == 0 ? "btn-primary" : "btn-secondary")"
                @onclick="() => _tab = 0">Alla</button>
        <button class="btn btn-sm @(_tab == 1 ? "btn-primary" : "btn-secondary")"
                @onclick="() => _tab = 1">
            <span class="material-icons" style="font-size:.82rem">checklist</span> Listor
        </button>
        <button class="btn btn-sm @(_tab == 2 ? "btn-primary" : "btn-secondary")"
                @onclick="() => _tab = 2">
            <span class="material-icons" style="font-size:.82rem">luggage</span> Packlistor
        </button>
        <button class="btn btn-sm @(_tab == 3 ? "btn-primary" : "btn-secondary")"
                @onclick="() => _tab = 3">
            <span class="material-icons" style="font-size:.82rem">sticky_note_2</span> Anteckningar
        </button>
        <button class="btn btn-sm @(_tab == 4 ? "btn-primary" : "btn-secondary")"
                @onclick="() => _tab = 4">
            <span class="material-icons" style="font-size:.82rem">folder_open</span> Projekt
        </button>
        <button class="btn btn-sm @(_tab == 5 ? "btn-primary" : "btn-secondary")"
                @onclick="() => _tab = 5">
            <span class="material-icons" style="font-size:.82rem">inventory_2</span> Inventarie
        </button>
    </div>

    <div class="page-content">
        @if (_loading)
        {
            <div style="text-align:center;padding:48px"><div class="spinner"></div></div>
        }
        else if (!Filtered.Any())
        {
            <EmptyListState Tab="_tab" CanEdit="BudgetState.CanEdit"
                            OnCreateList="() => OpenCreate(false)"
                            OnCreateNote="() => OpenCreate(true)" />
        }
        else
        {
            <div class="list-card-grid">
                @foreach (var item in Filtered)
                {
                    var it = item;
                    <ListTypeRenderer List="it"
                                      CanEdit="BudgetState.CanEdit"
                                      OnUpdated="OnListUpdated"
                                      OnDelete="DeleteAsync"
                                      OnOpen="OpenDetail" />
                }
            </div>
        }
    </div>
</div>

<!-- ═══ Mobile ═══════════════════════════════════════════════════════ -->
<div class="mobile-page-shell">
    <div class="mobile-topbar">
        <span class="mobile-title">Listor</span>
        @if (BudgetState.CanEdit)
        {
            <div style="display:flex;gap:6px">
                <button class="mobile-icon-btn" @onclick="() => OpenCreate(false)">
                    <span class="material-icons">checklist</span>
                </button>
                <button class="mobile-icon-btn" @onclick="() => OpenCreate(true)">
                    <span class="material-icons">sticky_note_2</span>
                </button>
            </div>
        }
    </div>

    <!-- Mobile chips -->
    <div class="mobile-chips" style="border-bottom:.5px solid var(--color-border)">
        <button class="mobile-chip @(_tab == 0 ? "active" : "")" @onclick="() => _tab = 0">Alla</button>
        <button class="mobile-chip @(_tab == 1 ? "active" : "")" @onclick="() => _tab = 1">Listor</button>
        <button class="mobile-chip @(_tab == 2 ? "active" : "")" @onclick="() => _tab = 2">🧳 Pack</button>
        <button class="mobile-chip @(_tab == 3 ? "active" : "")" @onclick="() => _tab = 3">Ant.</button>
        <button class="mobile-chip @(_tab == 4 ? "active" : "")" @onclick="() => _tab = 4">?</button>
        <button class="mobile-chip @(_tab == 5 ? "active" : "")"
                @onclick="() => _tab = 5">
            📦 Inv.
        </button>
    </div>

    <div class="mobile-page-scroll">
        @if (_loading)
        {
            <div style="text-align:center;padding:40px"><div class="spinner"></div></div>
        }
        else
        {
            @foreach (var item in Filtered)
            {
                var it = item;
                @if (it.ListType == ListType.Packing)
                {
                    <!-- Packing list gets full renderer on mobile too -->
                    <div class="card" style="margin-bottom:10px">
                        <div style="display:flex;align-items:center;gap:6px;margin-bottom:10px">
                            <span class="material-icons" style="font-size:.9rem;color:var(--color-muted)">luggage</span>
                            <span style="font-weight:600;font-size:.9rem">@it.Name</span>
                            @if (BudgetState.CanEdit)
                            {
                                <button class="btn btn-ghost btn-icon btn-sm" style="margin-left:auto"
                                        @onclick="() => DeleteAsync(it)">
                                    <span class="material-icons" style="font-size:.82rem;color:var(--color-expense)">delete</span>
                                </button>
                            }
                        </div>
                        <PackingListRenderer List="it" CanEdit="BudgetState.CanEdit"
                                            OnUpdated="OnListUpdated" />
                    </div>
                }
                else
                {
                    <!-- Compact mobile card for other types -->
                    <div class="mobile-entry-card" @onclick="() => OpenDetail(it)">
                        <div style="display:flex;align-items:flex-start;justify-content:space-between">
                            <div style="min-width:0;flex:1">
                                <div style="font-weight:500;font-size:.9rem;display:flex;
                                            align-items:center;gap:5px">
                                    <span class="material-icons" style="font-size:.85rem;
                                                 color:var(--color-muted)">
                                        @(it.IsNote ? "sticky_note_2" : "checklist")
                                    </span>
                                    @it.Name
                                </div>
                                @if (!it.IsNote && it.TotalItems > 0)
                                {
                                    <div class="mobile-entry-card-meta">
                                        @it.CheckedItems / @it.TotalItems klart
                                    </div>
                                }
                                @if (it.IsNote && !string.IsNullOrEmpty(it.Content))
                                {
                                    <div style="font-size:.78rem;color:var(--color-muted);
                                                overflow:hidden;max-height:36px;margin-top:2px">
                                        @it.Content
                                    </div>
                                }
                            </div>
                            @if (BudgetState.CanEdit)
                            {
                                <button class="btn btn-ghost btn-icon btn-sm" @onclick:stopPropagation
                                        @onclick="() => DeleteAsync(it)">
                                    <span class="material-icons" style="font-size:.82rem;
                                                 color:var(--color-expense)">delete</span>
                                </button>
                            }
                        </div>
                    </div>
                }
            }
        }
    </div>
    @if (BudgetState.CanEdit)
    {
        <button class="mobile-fab" @onclick="() => OpenCreate(false)">
            <span class="material-icons">add</span>
        </button>
    }
</div>

<!-- ═══ Create modal ════════════════════════════════════════════════ -->
@if (_showCreate)
{
    <div class="modal-overlay" @onclick="() => _showCreate = false">
        <div class="modal" style="max-width:480px" @onclick:stopPropagation>
            <div class="modal-header">
                <span class="modal-title">@(_isNote ? "Ny anteckning" : "Ny lista")</span>
                <button class="btn btn-ghost btn-icon btn-sm" @onclick="() => _showCreate = false">
                    <span class="material-icons">close</span>
                </button>
            </div>
            <div class="modal-body">
                @if (!string.IsNullOrEmpty(_createError))
                {
                    <div style="background:var(--color-expense-bg);color:var(--color-expense);
                                padding:8px 12px;border-radius:8px;font-size:.85rem;margin-bottom:10px">
                        @_createError
                    </div>
                }

                <div class="form-group">
                    <label class="form-label">Namn *</label>
                    <input class="form-control" @bind="_newName"
                           placeholder="@(_isNote ? "T.ex. Mötesanteckningar..." : "T.ex. Sommarsemester...")" />
                </div>

                @if (!_isNote)
                {
                    <div class="form-group">
                        <label class="form-label">Typ</label>
                        <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
                            @foreach (var (type, label, icon, desc) in ListTypeOptions)
                            {
                                var t = type;
                                <button class="btn @(_newListType == t ? "btn-primary" : "btn-secondary") btn-sm"
                                        style="justify-content:flex-start;gap:8px;padding:10px 12px;
                                               text-align:left;flex-direction:column;align-items:flex-start;
                                               height:auto"
                                        @onclick="() => _newListType = t">
                                    <div style="display:flex;align-items:center;gap:6px">
                                        <span class="material-icons" style="font-size:.9rem">@icon</span>
                                        <strong>@label</strong>
                                    </div>
                                    <span style="font-size:.72rem;opacity:.8;font-weight:400">@desc</span>
                                </button>
                            }
                        </div>
                    </div>
                }

                @if (_isNote)
                {
                    <div class="form-group">
                        <label class="form-label">Innehåll</label>
                        <textarea class="form-control" rows="5" @bind="_newContent"
                                  placeholder="Skriv din anteckning..."></textarea>
                    </div>
                }

                <div class="form-group">
                    <label class="form-label">Taggar</label>
                    <input class="form-control" @bind="_newTags"
                           placeholder="T.ex. semester, privat (komma-separerade)" />
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="() => _showCreate = false">Avbryt</button>
                <button class="btn btn-primary" @onclick="CreateAsync" disabled="@_saving">
                    @if (_saving) { <span class="spinner" style="width:14px;height:14px;border-width:2px"></span> }
                    Skapa
                </button>
            </div>
        </div>
    </div>
}

<!-- ═══ Detail modal (notes + legacy lists) ═════════════════════════ -->
<ListDetailModal ActiveList="_detailList"
                 CanEdit="BudgetState.CanEdit"
                 OnClose="() => _detailList = null"
                 OnUpdated="OnListUpdated"
                 OnDeleted="OnDetailDeleted" />

<ConfirmDialog @ref="_confirm" Title="Ta bort" Message="Ta bort detta objekt permanent?" />

@code {
    private List<UserListDto>  _all         = new();
    private List<int>          _scopeIds    = new();
    private int                _tab         = 0;
    private bool               _loading     = true;
    private bool               _showCreate, _isNote, _saving;
    private string             _createError = "";
    private string             _newName = "", _newContent = "", _newTags = "";
    private ListType           _newListType = ListType.CheckList;
    private UserListDto?       _detailList;
    private ConfirmDialog?     _confirm;

    private static readonly (ListType Type, string Label, string Icon, string Desc)[] ListTypeOptions =
    {
        (ListType.CheckList, "Checklista",  "checklist",      "Enkla checkboxar"),
        (ListType.Shopping,  "Inköpslista", "shopping_cart",  "Handla mat & varor"),
        (ListType.Packing,   "Packlista",   "luggage",        "Resa med kategorier"),
        (ListType.ToDo,      "Att-göra",    "task_alt",       "Uppgifter & todo"),
        (ListType.Custom,    "Progresslista","bar_chart",     "Spåra framsteg"),
        (ListType.Project,   "Projekt",     "folder_open",    "Status & delmål (Fas B)"),
        (ListType.Habit,    "Rutiner",      "repeat",      "Streaks & vanor"),
        (ListType.Decision, "Beslut",       "balance",     "Alternativ & magkänsla"),
        (ListType.Project,  "Projekt",      "folder_open", "Status & Kanban"),
        (ListType.Problem,   "Problem/Lösning", "psychology",  "Testa & dokumentera"),
        (ListType.Inventory, "Inventarie",      "inventory_2", "Värde & garantier"),
    };

    private IEnumerable<UserListDto> Filtered => _tab switch
    {
        1 => _all.Where(x => !x.IsNote && x.ListType is not
                 (ListType.Packing or ListType.Habit or ListType.Decision
                  or ListType.Project or ListType.Problem or ListType.Inventory)),
        2 => _all.Where(x => x.ListType == ListType.Packing),
        3 => _all.Where(x => x.IsNote),
        4 => _all.Where(x => x.ListType is ListType.Project
                           or ListType.Habit or ListType.Decision or ListType.Problem),
        5 => _all.Where(x => x.ListType == ListType.Inventory),
        _ => _all
    };

    protected override async Task OnInitializedAsync()
    {
        BudgetState.StateChanged += OnStateChanged;
        _scopeIds = new List<int> { BudgetState.ActiveBudgetId };
        await ReloadAsync();
    }

    public void Dispose() => BudgetState.StateChanged -= OnStateChanged;

    private void OnStateChanged() => InvokeAsync(async () =>
    {
        if (_showCreate || _detailList != null) return;
        await ReloadAsync();
        StateHasChanged();
    });

    private async Task ReloadAsync()
    {
        if (BudgetState.ActiveBudgetId <= 0) { _loading = false; return; }
        _loading = true;
        try { _all = await ListSvc.GetAllAsync(BudgetState.ActiveBudgetId) ?? new(); }
        catch (Exception ex) { Console.WriteLine($"[ListsPage] {ex.Message}"); }
        finally { _loading = false; }
    }

    private void OpenCreate(bool isNote)
    {
        _isNote = isNote; _newName = ""; _newContent = ""; _newTags = "";
        _newListType = ListType.CheckList; _createError = ""; _showCreate = true;
    }

    private async Task CreateAsync()
    {
        if (string.IsNullOrWhiteSpace(_newName)) { _createError = "Ange ett namn."; return; }
        _saving = true; _createError = "";
        try
        {
            var type = _isNote ? ListType.Note : _newListType;
            var dto  = new CreateListDto(
                _newName.Trim(), type, null,
                _isNote ? _newContent : null,
                string.IsNullOrWhiteSpace(_newTags) ? null : _newTags,
                EntryScope.BudgetSpecific, EntryVisibility.Private);

            await ListSvc.CreateAsync(BudgetState.ActiveBudgetId, dto);
            Toast.Success(_isNote ? "Anteckning skapad." : "Lista skapad.");
            _showCreate = false;
            await ReloadAsync();
        }
        catch (Exception ex) { _createError = ex.Message; }
        finally { _saving = false; }
    }

    private void OpenDetail(UserListDto list) => _detailList = list;

    private async Task OnListUpdated(UserListDto updated)
    {
        var idx = _all.FindIndex(l => l.Id == updated.Id);
        if (idx >= 0) { _all[idx] = updated; StateHasChanged(); }
        else await ReloadAsync();
    }

    private async Task OnDetailDeleted(int id)
    {
        _detailList = null;
        try
        {
            await ListSvc.DeleteAsync(BudgetState.ActiveBudgetId, id);
            Toast.Success("Borttaget.");
            await ReloadAsync();
        }
        catch (Exception ex) { Toast.Error(ex.Message); }
    }

    private async Task DeleteAsync(UserListDto item)
    {
        if (_confirm is null || !await _confirm.ShowAsync()) return;
        try
        {
            await ListSvc.DeleteAsync(BudgetState.ActiveBudgetId, item.Id);
            Toast.Success("Borttaget.");
            await ReloadAsync();
        }
        catch (Exception ex) { Toast.Error(ex.Message); }
    }
}