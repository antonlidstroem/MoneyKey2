@page "/admin"
@attribute [Authorize]
@implements IDisposable
@inject AdminApiService AdminSvc
@inject SubscriptionApiService SubSvc
@inject ToastService Toast
@inject BudgetState BudgetState
@inject NavigationManager Nav

@if (!BudgetState.IsSystemAdmin)
{
    <RedirectToLogin />
    return;
}

<div class="desktop-page-wrapper">
    <div class="page-header">
        <span class="page-title" style="color:var(--color-expense);display:flex;align-items:center;gap:8px">
            <span class="material-icons">admin_panel_settings</span>
            SuperAdmin
        </span>
    </div>

    <!-- Tab bar -->
    <div style="display:flex;gap:6px;padding:0 24px 0;border-bottom:1px solid var(--color-border);margin-bottom:0">
        <button class="btn btn-sm @(_tab == 0 ? "btn-primary" : "btn-ghost")"
                style="border-radius:6px 6px 0 0;margin-bottom:-1px;@(_tab == 0 ? "border-bottom:2px solid var(--color-primary)" : "")"
                @onclick="() => SetTab(0)">
            <span class="material-icons" style="font-size:.85rem">bar_chart</span> Statistik
        </button>
        <button class="btn btn-sm @(_tab == 1 ? "btn-primary" : "btn-ghost")"
                style="border-radius:6px 6px 0 0;margin-bottom:-1px;@(_tab == 1 ? "border-bottom:2px solid var(--color-primary)" : "")"
                @onclick="() => SetTab(1)">
            <span class="material-icons" style="font-size:.85rem">people</span> Användare
        </button>
        <button class="btn btn-sm @(_tab == 2 ? "btn-primary" : "btn-ghost")"
                style="border-radius:6px 6px 0 0;margin-bottom:-1px;@(_tab == 2 ? "border-bottom:2px solid var(--color-primary)" : "")"
                @onclick="() => SetTab(2)">
            <span class="material-icons" style="font-size:.85rem">wifi</span> SignalR
        </button>
    </div>

    <div class="page-content" style="padding-top:20px">

        <!-- ═══ TAB 0: Stats ═════════════════════════════════════════════════ -->
        @if (_tab == 0)
        {
            @if (_stats == null)
            {
                <div style="text-align:center;padding:48px"><div class="spinner"></div></div>
            }
            else
            {
                <div class="card-grid" style="grid-template-columns:repeat(auto-fit,minmax(140px,1fr));margin-bottom:20px">
                    <div class="kpi-card">
                        <div class="kpi-label">Totalt användare</div>
                        <div class="kpi-value">@_stats.Total</div>
                    </div>
                    <div class="kpi-card">
                        <div class="kpi-label">Betalda</div>
                        <div class="kpi-value income">@_stats.Paid</div>
                    </div>
                    <div class="kpi-card">
                        <div class="kpi-label">Utgångna</div>
                        <div class="kpi-value expense">@_stats.Expired</div>
                    </div>
                    <div class="kpi-card">
                        <div class="kpi-label">Admins</div>
                        <div class="kpi-value" style="color:#F9A825">@_stats.Admins</div>
                    </div>
                    <div class="kpi-card">
                        <div class="kpi-label">SignalR</div>
                        <div class="kpi-value @(_stats.SignalREnabled ? "income" : "expense")">
                            @(_stats.SignalREnabled ? "PÅ" : "AV")
                        </div>
                    </div>
                </div>

                <div class="card">
                    <div class="card-title">
                        <span class="material-icons">donut_large</span>
                        Prenumerationsfördelning
                    </div>
                    @foreach (var (tier, count) in _stats.TierCounts.OrderBy(x => x.Key))
                    {
                        var pct = _stats.Total > 0 ? count * 100 / _stats.Total : 0;
                        <div style="margin-bottom:12px">
                            <div style="display:flex;justify-content:space-between;font-size:.85rem;margin-bottom:4px">
                                <span style="font-weight:500">@tier</span>
                                <span style="color:var(--color-muted)">@count användare (@pct%)</span>
                            </div>
                            <div style="height:8px;background:var(--color-border);border-radius:4px;overflow:hidden">
                                <div style="height:100%;width:@pct%;background:var(--color-primary);border-radius:4px;transition:width .3s"></div>
                            </div>
                        </div>
                    }
                </div>
            }
        }

        <!-- ═══ TAB 1: Users ════════════════════════════════════════════════ -->
        @if (_tab == 1)
        {
            <div style="display:flex;gap:8px;margin-bottom:16px;align-items:center">
                <div class="quick-filter" style="max-width:340px;flex:1">
                    <span class="material-icons">search</span>
                    <input placeholder="Sök e-post eller smeknamn..."
                           value="@_search"
                           @oninput="OnSearchChange" />
                </div>
                @if (_usersLoading)
                {
                    <div class="spinner" style="width:18px;height:18px;border-width:2px"></div>
                }
                <span style="font-size:.82rem;color:var(--color-muted)">@_totalUsers användare totalt</span>
            </div>

            <div class="grid-container">
                <table style="width:100%;border-collapse:collapse" class="quickgrid">
                    <thead>
                        <tr>
                            <th>Smeknamn</th>
                            <th>E-post</th>
                            <th>Plan</th>
                            <th>Betald t.o.m.</th>
                            <th style="text-align:center">Budgetar</th>
                            <th style="text-align:center">Admin</th>
                            <th style="width:50px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (_usersLoading && !_users.Any())
                        {
                            <tr>
                                <td colspan="7" style="text-align:center;padding:32px">
                                    <div class="spinner" style="display:inline-block"></div>
                                </td>
                            </tr>
                        }
                        else if (!_users.Any())
                        {
                            <tr>
                                <td colspan="7" style="text-align:center;padding:24px;color:var(--color-muted)">
                                    Inga användare hittades.
                                </td>
                            </tr>
                        }
                        @foreach (var u in _users)
                        {
                            var user = u;
                            <tr>
                                <td style="font-weight:500">
                                    @u.DisplayName
                                    @if (string.IsNullOrEmpty(u.DisplayName))
                                    {
                                        <span style="color:var(--color-muted);font-style:italic">Ej satt</span>
                                    }
                                </td>
                                <td style="font-size:.82rem;color:var(--color-muted)">@u.Email</td>
                                <td>
                                    <span class="badge @TierBadge(u.Tier)" style="font-size:.72rem">@u.TierLabel</span>
                                </td>
                                <td style="font-size:.82rem">
                                    @if (u.PaidUntil.HasValue)
                                    {
                                        <span style="color:@(u.PaidUntil < DateTime.Today ? "var(--color-expense)" : "var(--color-income)")">
                                            @u.PaidUntil.Value.ToString("yyyy-MM-dd")
                                            @if (u.PaidUntil < DateTime.Today)
                                            {
                                                <span style="font-size:.75rem"> (utgången)</span>
                                            }
                                        </span>
                                    }
                                    else
                                    {
                                        <span style="color:var(--color-muted)">–</span>
                                    }
                                </td>
                                <td style="font-size:.82rem;text-align:center">@u.BudgetCount</td>
                                <td style="text-align:center">
                                    @if (u.IsAdmin)
                                    {
                                        <span class="material-icons" style="font-size:.95rem;color:#F9A825" title="SuperAdmin">star</span>
                                    }
                                </td>
                                <td>
                                    <button class="btn btn-ghost btn-icon btn-sm" title="Redigera"
                                            @onclick="() => OpenEditUser(user)">
                                        <span class="material-icons" style="font-size:.85rem">edit</span>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (_totalUsers > 50)
            {
                <div style="display:flex;gap:8px;justify-content:center;margin-top:14px;align-items:center">
                    <button class="btn btn-secondary btn-sm" disabled="@(_page <= 1)" @onclick="PrevPage">
                        <span class="material-icons" style="font-size:.85rem">chevron_left</span> Föregående
                    </button>
                    <span style="font-size:.85rem;color:var(--color-muted)">Sida @_page</span>
                    <button class="btn btn-secondary btn-sm" disabled="@(_users.Count < 50)" @onclick="NextPage">
                        Nästa <span class="material-icons" style="font-size:.85rem">chevron_right</span>
                    </button>
                </div>
            }
        }

        <!-- ═══ TAB 2: SignalR ═══════════════════════════════════════════════ -->
        @if (_tab == 2)
        {
            <div class="card" style="max-width:480px">
                <div class="card-title">
                    <span class="material-icons">wifi</span>
                    SignalR realtidsuppdateringar
                </div>
                @if (_signalRLoading)
                {
                    <div style="text-align:center;padding:24px"><div class="spinner"></div></div>
                }
                else
                {
                    <div style="display:flex;align-items:center;gap:16px;padding:16px;background:var(--color-bg);border-radius:10px;margin-bottom:16px">
                        <span class="material-icons" style="font-size:2.5rem;color:@(_signalREnabled ? "var(--color-income)" : "var(--color-muted)")">
                            @(_signalREnabled ? "wifi" : "wifi_off")
                        </span>
                        <div>
                            <div style="font-weight:600;font-size:.95rem;margin-bottom:4px">
                                Status: <span style="color:@(_signalREnabled ? "var(--color-income)" : "var(--color-expense)")">
                                @(_signalREnabled ? "Aktiverat" : "Inaktiverat")
                            </span>
                        </div>
                        <div style="font-size:.82rem;color:var(--color-muted)">
                            @(_signalREnabled
                                ? "Realtidsuppdateringar är aktiva. Alla budgetmedlemmar ser ändringar direkt utan att ladda om sidan."
                                : "SignalR är avstängt. Användare måste ladda om sidan manuellt för att se ändringar.")
                        </div>
                    </div>
                </div>
                <button class="btn @(_signalREnabled ? "btn-secondary" : "btn-primary") btn-sm"
                        @onclick="ToggleSignalRAsync" style="min-width:140px">
                    <span class="material-icons" style="font-size:.9rem">
                        @(_signalREnabled ? "toggle_off" : "toggle_on")
                    </span>
                    @(_signalREnabled ? "Stäng av SignalR" : "Aktivera SignalR")
                </button>
                <div style="margin-top:14px;font-size:.78rem;color:var(--color-muted)">
                    💡 Stäng av SignalR för att minska CPU-användning på servern när realtidsuppdateringar inte behövs.
                </div>
            }
        </div>
    }
</div>
</div>

<!-- Mobile shell -->
<div class="mobile-page-shell">
    <div class="mobile-topbar">
        <span class="mobile-title" style="color:var(--color-expense)">SuperAdmin</span>
    </div>
    <div class="mobile-chips">
        <button class="mobile-chip @(_tab == 0 ? "active" : "")" @onclick="() => SetTab(0)">Statistik</button>
        <button class="mobile-chip @(_tab == 1 ? "active" : "")" @onclick="() => SetTab(1)">Användare</button>
        <button class="mobile-chip @(_tab == 2 ? "active" : "")" @onclick="() => SetTab(2)">SignalR</button>
    </div>
    <div class="mobile-page-scroll">
        @if (_tab == 0 && _stats != null)
        {
            <div class="mobile-entry-card">
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
                    <div><div style="font-size:.72rem;color:var(--color-muted)">Totalt</div><div style="font-weight:700">@_stats.Total</div></div>
                    <div><div style="font-size:.72rem;color:var(--color-muted)">Betalda</div><div style="font-weight:700;color:var(--color-income)">@_stats.Paid</div></div>
                    <div><div style="font-size:.72rem;color:var(--color-muted)">Admins</div><div style="font-weight:700;color:#F9A825">@_stats.Admins</div></div>
                    <div><div style="font-size:.72rem;color:var(--color-muted)">SignalR</div><div style="font-weight:700;color:@(_stats.SignalREnabled ? "var(--color-income)" : "var(--color-expense)")">@(_stats.SignalREnabled ? "PÅ" : "AV")</div></div>
                </div>
            </div>
        }
        @if (_tab == 1)
        {
            @foreach (var u in _users)
            {
                var user = u;
                <div class="mobile-entry-card">
                    <div style="display:flex;justify-content:space-between;align-items:flex-start">
                        <div>
                            <div style="font-weight:500">@(u.DisplayName.Length > 0 ? u.DisplayName : "–")</div>
                            <div style="font-size:.78rem;color:var(--color-muted)">@u.Email</div>
                        </div>
                        <div style="display:flex;gap:4px;align-items:center">
                            <span class="badge @TierBadge(u.Tier)" style="font-size:.68rem">@u.TierLabel</span>
                            @if (u.IsAdmin)
                            {
                                <span class="material-icons" style="font-size:.9rem;color:#F9A825">star</span>
                            }
                            <button class="btn btn-ghost btn-icon btn-sm" @onclick="() => OpenEditUser(user)">
                                <span class="material-icons" style="font-size:.82rem">edit</span>
                            </button>
                        </div>
                    </div>
                </div>
            }
        }
        @if (_tab == 2 && !_signalRLoading)
        {
            <div class="mobile-entry-card">
                <div style="font-weight:600;margin-bottom:8px">
                    SignalR: <span style="color:@(_signalREnabled ? "var(--color-income)" : "var(--color-expense)")">
                    @(_signalREnabled ? "Aktiverat" : "Inaktiverat")
                </span>
            </div>
            <button class="btn @(_signalREnabled ? "btn-secondary" : "btn-primary") btn-sm"
                    style="width:100%" @onclick="ToggleSignalRAsync">
                @(_signalREnabled ? "Stäng av" : "Aktivera")
            </button>
        </div>
    }
</div>
</div>

<!-- ═══ Edit user modal ═══════════════════════════════════════════════════ -->
@if (_editUser != null)
{
    <div class="modal-overlay" @onclick="() => _editUser = null"
         @onkeydown='e => { if (e.Key == "Escape") _editUser = null; }'>
        <div class="modal" style="max-width:500px" @onclick:stopPropagation>
            <div class="modal-header">
                <span class="modal-title">Redigera — @_editUser.DisplayName</span>
                <button class="btn btn-ghost btn-icon btn-sm" @onclick="() => _editUser = null">
                    <span class="material-icons">close</span>
                </button>
            </div>
            <div class="modal-body">
                <div style="background:var(--color-bg);border-radius:8px;padding:10px 14px;font-size:.82rem;margin-bottom:14px;color:var(--color-muted)">
                    <span class="material-icons" style="font-size:.85rem;vertical-align:middle;margin-right:4px">info</span>
                    @_editUser.Email · Registrerad @_editUser.CreatedAt.ToString("yyyy-MM-dd")
                </div>

                <div class="form-group">
                    <label class="form-label">Prenumerationsplan</label>
                    <select class="form-control" @bind="_editTier">
                        @foreach (var t in Enum.GetValues<SubscriptionTier>())
                        {
                            <option value="@t">@SubscriptionLimits.TierLabel(t)</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Betald till och med</label>
                    <input class="form-control" type="date"
                           value="@(_editPaidUntil?.ToString("yyyy-MM-dd") ?? "")"
                           @onchange='e => {
                                               var s = e.Value?.ToString();
                                               _editPaidUntil = string.IsNullOrEmpty(s) ? null
                                                   : DateTime.TryParse(s, out var d) ? d : _editPaidUntil;
                                           }' />
            </div>
            <div class="form-group">
                <label class="form-label">Betalningsreferens</label>
                <input class="form-control" @bind="_editPayRef" placeholder="T.ex. Stripe-id, Swish-ref..." />
            </div>

            <div style="padding:12px;background:var(--color-bg);border-radius:8px;margin-bottom:14px">
                <label style="display:flex;align-items:center;gap:10px;cursor:pointer">
                    <input type="checkbox" @bind="_editIsAdmin" />
                    <div>
                        <div style="font-weight:500;font-size:.875rem">SuperAdmin</div>
                        <div style="font-size:.75rem;color:var(--color-muted)">Kan administrera alla användare och se admin-panelen</div>
                    </div>
                </label>
            </div>

            <div class="form-group">
                <label class="form-label">Admin-anteckningar (intern)</label>
                <textarea class="form-control" rows="3" @bind="_editNotes"
                          placeholder="Intern anteckning om användaren..."></textarea>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" @onclick="() => _editUser = null">Avbryt</button>
            <button class="btn btn-primary" @onclick="SaveUserAsync" disabled="@_saving">
                @if (_saving)
                {
                    <span class="spinner" style="width:14px;height:14px;border-width:2px"></span>
                }
                Spara ändringar
            </button>
        </div>
    </div>
</div>
}

@code {
    private int _tab = 0;
    private bool _usersLoading, _signalRLoading, _saving;
    private string _search = "";
    private int _page = 1;
    private int _totalUsers;
    private bool _signalREnabled;

    private AdminStatsResult? _stats;
    private List<AdminUserDto> _users = new();
    private AdminUserDto? _editUser;
    private SubscriptionTier _editTier;
    private DateTime? _editPaidUntil;
    private string? _editPayRef, _editNotes;
    private bool _editIsAdmin;

    private System.Threading.Timer? _debounce;

    public void Dispose() => _debounce?.Dispose();

    protected override async Task OnInitializedAsync()
    {
        await SetTab(0);
    }

    private async Task SetTab(int t)
    {
        _tab = t;
        if (t == 0 && _stats == null) await LoadStatsAsync();
        if (t == 1 && !_users.Any()) await LoadUsersAsync();
        if (t == 2) await LoadSignalRAsync();
        StateHasChanged();
    }

    private async Task LoadStatsAsync()
    {
        try { _stats = await AdminSvc.GetStatsAsync(); }
        catch (Exception ex) { Toast.Error(ex.Message); }
    }

    private async Task LoadUsersAsync()
    {
        _usersLoading = true; StateHasChanged();
        try
        {
            var r = await AdminSvc.GetUsersAsync(_search.Length >= 2 ? _search : null, _page);
            _users = r?.Users ?? new();
            _totalUsers = r?.Total ?? 0;
        }
        catch (Exception ex) { Toast.Error(ex.Message); }
        finally { _usersLoading = false; }
    }

    private async Task LoadSignalRAsync()
    {
        _signalRLoading = true; StateHasChanged();
        try
        {
            var r = await AdminSvc.GetSignalRStatusAsync();
            _signalREnabled = r?.Enabled ?? false;
        }
        catch { }
        finally { _signalRLoading = false; }
    }

    private void OnSearchChange(ChangeEventArgs e)
    {
        _search = e.Value?.ToString() ?? "";
        _debounce?.Dispose();
        _debounce = new System.Threading.Timer(async _ =>
        {
            _page = 1;
            await InvokeAsync(async () => { await LoadUsersAsync(); StateHasChanged(); });
        }, null, 400, System.Threading.Timeout.Infinite);
    }

    private async Task PrevPage() { if (_page > 1) { _page--; await LoadUsersAsync(); } }
    private async Task NextPage() { _page++; await LoadUsersAsync(); }

    private void OpenEditUser(AdminUserDto u)
    {
        _editUser = u;
        _editTier = u.Tier;
        _editPaidUntil = u.PaidUntil;
        _editPayRef = null;
        _editNotes = u.AdminNotes;
        _editIsAdmin = u.IsAdmin;
    }

    private async Task SaveUserAsync()
    {
        if (_editUser == null) return;
        _saving = true;
        try
        {
            await AdminSvc.UpdateSubscriptionAsync(_editUser.UserId, new UpdateSubscriptionDto
            {
                Tier = _editTier,
                PaidUntil = _editPaidUntil,
                PaymentRef = _editPayRef,
                IsAdmin = _editIsAdmin,
                AdminNotes = _editNotes
            });
            Toast.Success($"{_editUser.DisplayName} uppdaterad.");
            _editUser = null;
            _stats = null;
            await LoadUsersAsync();
            await LoadStatsAsync();
        }
        catch (Exception ex) { Toast.Error(ex.Message); }
        finally { _saving = false; }
    }

    private async Task ToggleSignalRAsync()
    {
        try
        {
            await AdminSvc.ToggleSignalRAsync(!_signalREnabled);
            _signalREnabled = !_signalREnabled;
            Toast.Success(_signalREnabled ? "SignalR aktiverat." : "SignalR inaktiverat.");
            _stats = null;
            await LoadStatsAsync();
        }
        catch (Exception ex) { Toast.Error(ex.Message); }
    }

    private static string TierBadge(SubscriptionTier t) => t switch
    {
        SubscriptionTier.Free => "badge-muted",
        SubscriptionTier.Plus => "badge",
        SubscriptionTier.Pro => "badge-income",
        SubscriptionTier.Enterprise => "badge-primary",
        _ => "badge-muted"
    };
}
