@page "/vab"
@attribute [Authorize]
@implements IDisposable
@inject VabApiService VabSvc
@inject ToastService Toast
@inject BudgetState BudgetState

<div class="desktop-page-wrapper">
    <div class="page-header">
        <span class="page-title">VAB-perioder</span>
        @if (BudgetState.CanEdit) { <div class="header-actions"><button class="btn btn-primary btn-sm" @onclick='() => _showForm = true'><span class="material-icons" style="font-size:.9rem">add</span> Ny VAB</button></div> }
    </div>
    <div class="page-content">
        @if (_loading) { <div style="text-align:center;padding:40px"><div class="spinner"></div></div> }
        else {
            <div class="grid-container">
                <table style="width:100%;border-collapse:collapse" class="quickgrid">
                    <thead><tr><th>Barn</th><th>Från</th><th>Till</th><th style="text-align:right">Dagar</th><th style="text-align:right">Dagersättning</th><th style="text-align:right">Nivå</th><th style="text-align:right">Totalt</th>@if(BudgetState.CanEdit){<th style="width:40px"></th>}</tr></thead>
                    <tbody>
                        @if (!_items.Any()) { <tr><td colspan="8" style="text-align:center;padding:24px;color:var(--color-muted)">Inga VAB-perioder registrerade.</td></tr> }
                        @foreach (var v in _items) {
                            var item = v;
                            <tr>
                                <td style="font-size:.85rem">@(v.ChildName ?? "–")</td>
                                <td style="font-size:.85rem">@v.StartDate.ToString("yyyy-MM-dd")</td>
                                <td style="font-size:.85rem">@v.EndDate.ToString("yyyy-MM-dd")</td>
                                <td style="text-align:right;font-size:.85rem">@v.TotalDays</td>
                                <td style="text-align:right;font-size:.85rem">@v.DailyBenefit.ToString("N0") kr</td>
                                <td style="text-align:right;font-size:.85rem">@((v.Rate * 100).ToString("N0"))%</td>
                                <td style="text-align:right;font-weight:600;font-size:.875rem;color:var(--color-expense)">−@v.TotalAmount.ToString("N2") kr</td>
                                @if(BudgetState.CanEdit){<td><button class="btn btn-ghost btn-icon btn-sm" @onclick="() => DeleteAsync(item.Id)"><span class="material-icons" style="font-size:.9rem;color:var(--color-expense)">delete</span></button></td>}
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<div class="mobile-page-shell">
    <div class="mobile-topbar"><span class="mobile-title">VAB-perioder</span>@if(BudgetState.CanEdit){<button class="mobile-icon-btn" @onclick='() => _showForm = true'><span class="material-icons">add</span></button>}</div>
    <div class="mobile-page-scroll">
        @if (_loading) { <div style="text-align:center;padding:40px"><div class="spinner"></div></div> }
        else if (!_items.Any()) { <div style="text-align:center;padding:48px 24px;color:var(--color-muted)"><span class="material-icons" style="font-size:2.5rem;display:block;margin-bottom:8px">child_care</span>Inga VAB-perioder registrerade</div> }
        else {
            @foreach (var v in _items) {
                var item = v;
                <div class="mobile-entry-card">
                    <div class="mobile-entry-card-header">
                        <div>
                            <div class="mobile-entry-card-title">@(v.ChildName ?? "VAB")</div>
                            <div class="mobile-entry-card-meta">@v.StartDate.ToString("yyyy-MM-dd") – @v.EndDate.ToString("yyyy-MM-dd") · @v.TotalDays dag@(v.TotalDays != 1 ? "ar" : "") · @((v.Rate * 100).ToString("N0"))%</div>
                            <div class="mobile-entry-card-meta">@v.DailyBenefit.ToString("N0") kr/dag</div>
                        </div>
                        <div style="text-align:right;flex-shrink:0">
                            <div class="mobile-entry-card-amount amount-neg">−@v.TotalAmount.ToString("N0") kr</div>
                            @if(BudgetState.CanEdit){<button class="btn btn-ghost btn-icon btn-sm" style="margin-top:4px" @onclick="() => DeleteAsync(item.Id)"><span class="material-icons" style="font-size:.9rem;color:var(--color-expense)">delete</span></button>}
                        </div>
                    </div>
                </div>
            }
        }
    </div>
    @if(BudgetState.CanEdit){<button class="mobile-fab" @onclick='() => _showForm = true'><span class="material-icons">add</span></button>}
</div>

@if (_showForm)
{
    <div class="modal-overlay" @onclick='() => _showForm = false'>
        <div class="modal" @onclick:stopPropagation>
            <div class="modal-header"><span class="modal-title">Ny VAB-period</span></div>
            <div class="modal-body">
                <div class="form-group"><label class="form-label">Barnets namn</label><input class="form-control" @bind="_child" placeholder="Valfritt" /></div>
                <div class="form-row">
                    <div class="form-group"><label class="form-label">Från</label><input class="form-control" type="date" value="@_start.ToString("yyyy-MM-dd")" @onchange='e => _start = DateTime.Parse(e.Value!.ToString()!)' /></div>
                    <div class="form-group"><label class="form-label">Till</label><input class="form-control" type="date" value="@_end.ToString("yyyy-MM-dd")" @onchange='e => _end = DateTime.Parse(e.Value!.ToString()!)' /></div>
                </div>
                <div class="form-row">
                    <div class="form-group"><label class="form-label">Dagersättning (kr)</label><input class="form-control" type="number" @bind="_benefit" /></div>
                    <div class="form-group"><label class="form-label">Ersättningsnivå (0–1)</label><input class="form-control" type="number" step="0.01" min="0" max="1" @bind="_rate" /></div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick='() => _showForm = false'>Avbryt</button>
                <button class="btn btn-primary" @onclick="CreateAsync" disabled="@_saving">
                    @if (_saving) { <span class="spinner" style="width:14px;height:14px;border-width:2px"></span> } Spara
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<VabDto> _items = new();
    private bool _loading = true, _showForm, _saving;
    private string? _child;
    private DateTime _start = DateTime.Today, _end = DateTime.Today;
    private decimal _benefit, _rate = 0.8m;

    protected override async Task OnInitializedAsync() { BudgetState.StateChanged += OnStateChanged; await ReloadAsync(); }
    public void Dispose() => BudgetState.StateChanged -= OnStateChanged;
    private void OnStateChanged() => InvokeAsync(async () => { try { await ReloadAsync(); } catch (Exception ex) { Toast.Error($"Laddningsfel: {ex.Message}"); } StateHasChanged(); });
    private async Task ReloadAsync() { if (BudgetState.ActiveBudgetId <= 0) { _loading = false; return; } _loading = true; _items = await VabSvc.GetAllAsync(BudgetState.ActiveBudgetId) ?? new(); _loading = false; }
    private async Task CreateAsync() { _saving = true; try { await VabSvc.CreateAsync(BudgetState.ActiveBudgetId, new CreateVabDto(_child, _start, _end, _benefit, _rate)); Toast.Success("VAB sparad."); _showForm = false; await ReloadAsync(); } catch (Exception ex) { Toast.Error(ex.Message); } finally { _saving = false; } }
    private async Task DeleteAsync(int id) { try { await VabSvc.DeleteAsync(BudgetState.ActiveBudgetId, id); Toast.Success("Borttagen."); await ReloadAsync(); } catch (Exception ex) { Toast.Error(ex.Message); } }
}
