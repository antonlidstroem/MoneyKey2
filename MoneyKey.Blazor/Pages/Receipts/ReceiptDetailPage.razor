@page "/receipts/{BatchId:int}"
@attribute [Authorize]
@inject ReceiptApiService ReceiptSvc
@inject ToastService Toast
@inject BudgetState BudgetState
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject HttpClient Http
@using MoneyKey.Blazor.Components.Shared

<div class="desktop-page-wrapper">
    <div class="page-header">
        <div style="display:flex;align-items:center;gap:10px">
            <button class="btn btn-ghost btn-sm" @onclick='() => Nav.NavigateTo("/receipts")'><span class="material-icons" style="font-size:.9rem">arrow_back</span></button>
            <span class="page-title">@(_batch?.Label ?? "Kvittounderlag")</span>
            @if (_batch != null) { <span class="badge @SBadge(_batch.Status)" style="font-size:.75rem">@_batch.StatusLabel</span> }
        </div>
        <div class="header-actions">
            @if (_batch != null) { <button class="btn btn-secondary btn-sm" @onclick="ExportPdfAsync" disabled="@_exporting">@if(_exporting){<span class="spinner" style="width:12px;height:12px;border-width:2px"></span>}else{<span class="material-icons" style="font-size:.9rem">picture_as_pdf</span>}Ladda ned PDF</button> }
        </div>
    </div>
    <div class="page-content" style="display:grid;grid-template-columns:1fr 300px;gap:16px;align-items:start">
        @if (_batch == null) { <div style="text-align:center;padding:48px"><div class="spinner"></div></div> }
        else {
            <div>
                <div class="card">
                    <div class="card-title"><span class="material-icons">receipt_long</span> Kvittolinjer</div>
                    <table style="width:100%;border-collapse:collapse" class="quickgrid">
                        <thead><tr><th style="width:30px">#</th><th style="width:110px">Referenskod</th><th style="width:90px">Datum</th><th>Leverantör</th><th>Beskrivning</th><th style="width:55px">Valuta</th><th style="text-align:right;width:90px">Belopp</th>@if(_batch.Status==ReceiptBatchStatus.Draft&&BudgetState.CanEdit){<th style="width:36px"></th>}</tr></thead>
                        <tbody>
                            @foreach (var line in _batch.Lines.OrderBy(l => l.SequenceNumber)) {
                                var ln = line;
                                <tr>
                                    <td style="font-size:.8rem;color:var(--color-muted)">@ln.SequenceNumber</td>
                                    <td><span style="font-family:monospace;font-weight:700;font-size:.85rem;color:var(--color-primary)">@ln.ReferenceCode</span></td>
                                    <td style="font-size:.85rem">@ln.Date.ToString("yyyy-MM-dd")</td>
                                    <td style="font-size:.85rem">@(ln.Vendor ?? "–")</td>
                                    <td style="font-size:.85rem">@(ln.Description ?? "–")</td>
                                    <td style="font-size:.8rem;color:var(--color-muted)">@ln.Currency</td>
                                    <td style="text-align:right;font-weight:600;font-size:.875rem">@ln.Amount.ToString("N2") kr</td>
                                    @if(_batch.Status==ReceiptBatchStatus.Draft&&BudgetState.CanEdit){<td><button class="btn btn-ghost btn-icon btn-sm" @onclick="() => DeleteLineAsync(ln.Id)"><span class="material-icons" style="font-size:.9rem;color:var(--color-expense)">delete</span></button></td>}
                                </tr>
                            }
                            <tr style="border-top:2px solid var(--color-border);font-weight:600">
                                <td colspan="6" style="text-align:right;padding:8px 12px;font-size:.875rem">Totalt:</td>
                                <td style="text-align:right;padding:8px 12px;font-size:.875rem">@_batch.TotalAmount.ToString("N2") kr</td>
                                @if(_batch.Status==ReceiptBatchStatus.Draft&&BudgetState.CanEdit){<td></td>}
                            </tr>
                        </tbody>
                    </table>
                    @if (_batch.Status == ReceiptBatchStatus.Draft && BudgetState.CanEdit) {
                        <div style="margin-top:16px;padding-top:16px;border-top:1px solid var(--color-border)">
                            <div class="card-title" style="margin-bottom:10px;font-size:.9rem">Lägg till kvitto</div>
                            <div style="font-size:.78rem;color:var(--color-muted);margin-bottom:6px">Nästa referenskod: <span style="font-family:monospace;font-weight:700;color:var(--color-primary);font-size:.85rem;margin-left:4px">@_previewCode</span></div>
                            @AddLineFormMarkup()
                        </div>
                    }
                </div>
            </div>
            <div><StatusActionBar Batch="_batch" OnStatusChanged="OnBatchStatusChanged" /></div>
        }
    </div>
</div>

<div class="mobile-page-shell">
    <div class="mobile-topbar">
        <div style="display:flex;align-items:center;gap:8px;overflow:hidden;flex:1">
            <button class="mobile-icon-btn" @onclick='() => Nav.NavigateTo("/receipts")'><span class="material-icons" style="font-size:1.1rem">arrow_back</span></button>
            <span class="mobile-title" style="overflow:hidden;text-overflow:ellipsis">@(_batch?.Label ?? "Kvittounderlag")</span>
        </div>
        @if (_batch != null) { <button class="mobile-icon-btn" @onclick="ExportPdfAsync" disabled="@_exporting" title="Ladda ned PDF">@if(_exporting){<span class="spinner" style="width:14px;height:14px;border-width:2px"></span>}else{<span class="material-icons" style="font-size:1rem">picture_as_pdf</span>}</button> }
    </div>
    <div class="mobile-page-scroll">
        @if (_batch == null) { <div style="text-align:center;padding:40px"><div class="spinner"></div></div> }
        else {
            <div style="margin-bottom:14px"><StatusActionBar Batch="_batch" OnStatusChanged="OnBatchStatusChanged" /></div>
            <div class="mobile-entry-card" style="margin-bottom:14px">
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px">
                    <span style="font-weight:500;font-size:.9rem">Kvittolinjer (@_batch.Lines.Count)</span>
                    <span style="font-weight:700;font-size:.9rem">@_batch.TotalAmount.ToString("N2") kr</span>
                </div>
                @foreach (var line in _batch.Lines.OrderBy(l => l.SequenceNumber)) { var ln = line;
                    <div class="mobile-receipt-line">
                        <div style="flex:1;min-width:0">
                            <div class="mobile-receipt-ref">@ln.ReferenceCode</div>
                            <div style="font-size:.82rem;color:var(--color-dark);margin-top:1px">@(ln.Vendor ?? "–")@if(ln.Description!=null){<span style="color:var(--color-muted)"> · @ln.Description</span>}</div>
                            <div style="font-size:.75rem;color:var(--color-muted)">@ln.Date.ToString("yyyy-MM-dd") · @ln.Currency</div>
                        </div>
                        <div style="text-align:right;flex-shrink:0">
                            <div style="font-weight:600;font-size:.875rem">@ln.Amount.ToString("N2") kr</div>
                            @if(_batch.Status==ReceiptBatchStatus.Draft&&BudgetState.CanEdit){<button class="btn btn-ghost btn-icon btn-sm" style="padding:4px" @onclick="() => DeleteLineAsync(ln.Id)"><span class="material-icons" style="font-size:.85rem;color:var(--color-expense)">delete</span></button>}
                        </div>
                    </div>
                }
            </div>
            @if (_batch.Status == ReceiptBatchStatus.Draft && BudgetState.CanEdit) {
                <div class="mobile-entry-card">
                    <div style="font-weight:500;font-size:.9rem;margin-bottom:8px">Lägg till kvitto</div>
                    <div style="font-size:.78rem;color:var(--color-muted);margin-bottom:8px">Nästa referenskod: <span style="font-family:monospace;font-weight:700;color:var(--color-primary);font-size:.85rem;margin-left:4px">@_previewCode</span></div>
                    @AddLineFormMarkup()
                </div>
            }
        }
    </div>
</div>

<ConfirmDialog @ref="_confirm" Title="Ta bort kvittorad" Message="Är du säker?" />

@code {
    [Parameter] public int BatchId { get; set; }

    private ReceiptBatchDto? _batch;
    private ConfirmDialog?   _confirm;
    private DateTime _newDate   = DateTime.Today;
    private decimal  _newAmount;
    private string?  _newVendor, _newDesc;
    private string   _previewCode = "…";
    private bool     _adding, _exporting;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _batch = await ReceiptSvc.GetByIdAsync(BudgetState.ActiveBudgetId, BatchId);
        if (_batch != null) _previewCode = BuildPreviewCode(_batch);
    }

    private static string BuildPreviewCode(ReceiptBatchDto b)
    {
        var next = (b.Lines.Any() ? b.Lines.Max(l => l.SequenceNumber) : 0) + 1;
        var bw   = b.Id   > 999 ? "D4" : "D3"; var sw = next > 999 ? "D4" : "D3";
        return $"{DateTime.UtcNow.Year}-{b.Id.ToString(bw)}-{next.ToString(sw)}";
    }

    private RenderFragment AddLineFormMarkup() =>
        @<div>
            <div class="form-row" style="margin-bottom:8px">
                <div class="form-group"><label class="form-label">Datum *</label><input class="form-control" type="date" value="@_newDate.ToString("yyyy-MM-dd")" @onchange='e => { if (DateTime.TryParse(e.Value?.ToString(), out var d)) _newDate = d; }' /></div>
                <div class="form-group"><label class="form-label">Belopp (SEK) *</label><input class="form-control" type="number" step="0.01" @bind="_newAmount" /></div>
            </div>
            <div class="form-row" style="margin-bottom:10px">
                <div class="form-group"><label class="form-label">Leverantör</label><input class="form-control" @bind="_newVendor" placeholder="Butik, restaurang..." /></div>
                <div class="form-group"><label class="form-label">Beskrivning</label><input class="form-control" @bind="_newDesc" placeholder="Vad avser kvittot?" /></div>
            </div>
            <button class="btn btn-primary btn-sm" @onclick="AddLineAsync" disabled="@_adding">
                @if (_adding) { <span class="spinner" style="width:14px;height:14px;border-width:2px"></span> }
                <span class="material-icons" style="font-size:.9rem">add</span> Lägg till
            </button>
        </div>;

    private async Task AddLineAsync()
    {
        if (_newAmount <= 0) { Toast.Error("Ange ett belopp större än 0."); return; }
        _adding = true;
        try { await ReceiptSvc.AddLineAsync(BudgetState.ActiveBudgetId, BatchId, new CreateReceiptLineDto(BudgetState.ActiveBudgetId, _newDate, _newAmount, _newVendor, _newDesc)); Toast.Success("Kvittorad tillagd."); _newAmount = 0; _newVendor = null; _newDesc = null; await LoadAsync(); }
        catch (Exception ex) { Toast.Error(ex.Message); }
        finally { _adding = false; }
    }

    private async Task DeleteLineAsync(int lineId)
    {
        if (_confirm == null || !await _confirm.ShowAsync()) return;
        try { await ReceiptSvc.DeleteLineAsync(BudgetState.ActiveBudgetId, BatchId, lineId); Toast.Success("Rad borttagen."); await LoadAsync(); }
        catch (Exception ex) { Toast.Error(ex.Message); }
    }

    private async Task OnBatchStatusChanged(ReceiptBatchDto updated) { _batch = updated; Toast.Success($"Status ändrad till: {updated.StatusLabel}"); StateHasChanged(); }

    private async Task ExportPdfAsync()
    {
        _exporting = true;
        try { var url = ReceiptSvc.GetPdfUrl(BudgetState.ActiveBudgetId, BatchId); var response = await Http.GetAsync(url); if (!response.IsSuccessStatusCode) { Toast.Error("Export misslyckades."); return; } var base64 = Convert.ToBase64String(await response.Content.ReadAsByteArrayAsync()); var label = _batch?.Label?.Replace(" ", "_") ?? BatchId.ToString(); await JS.InvokeVoidAsync("downloadFile", $"utlagg_{label}_{DateTime.Today:yyyyMMdd}.pdf", "application/pdf", base64); }
        catch (Exception ex) { Toast.Error($"Export misslyckades: {ex.Message}"); }
        finally { _exporting = false; }
    }

    private static string SBadge(ReceiptBatchStatus s) => s switch { ReceiptBatchStatus.Draft => "badge-muted", ReceiptBatchStatus.Submitted => "badge", ReceiptBatchStatus.Approved => "badge-income", ReceiptBatchStatus.Rejected => "badge-expense", ReceiptBatchStatus.Reimbursed => "badge-primary", _ => "badge-muted" };
}
