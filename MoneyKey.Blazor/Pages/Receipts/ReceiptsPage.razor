@page "/receipts"
@attribute [Authorize]
@implements IDisposable
@inject ReceiptApiService ReceiptSvc
@inject ToastService Toast
@inject BudgetState BudgetState
@inject NavigationManager Nav
@inject HttpClient Http
@inject IJSRuntime JS

<div class="desktop-page-wrapper">
    <div class="page-header">
        <span class="page-title">Kvittounderlag</span>
        @if (BudgetState.CanEdit)
        {
            <div class="header-actions">
                <button class="btn btn-primary btn-sm" @onclick='() => _showCreate = true'>
                    <span class="material-icons" style="font-size:.9rem">add</span> Nytt underlag
                </button>
            </div>
        }
    </div>
    <div class="page-content">
        <div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:12px">
            <button class="btn btn-sm @(_sf == null ? "btn-primary" : "btn-secondary")" @onclick="() => SetFilter(null)">Alla</button>
            @foreach (var s in Enum.GetValues<ReceiptBatchStatus>())
            { var status = s; <button class="btn btn-sm @(_sf == status ? "btn-primary" : "btn-secondary")" @onclick="() => SetFilter(status)">@Sw(status)</button> }
        </div>
        <div class="grid-container">
            <table style="width:100%;border-collapse:collapse" class="quickgrid">
                <thead>
                    <tr>
                        <th>Etikett</th><th>Kategori</th><th>Projekt</th>
                        <th style="text-align:right">Kvitton</th>
                        <th style="text-align:right">Totalt</th>
                        <th>Status</th><th>Skapad av</th><th>Datum</th>
                        <th style="width:70px"></th>
                    </tr>
                </thead>
                <tbody>
                    @if (_loading) { <tr><td colspan="9" style="text-align:center;padding:32px"><div class="spinner"></div></td></tr> }
                    else if (!_batches.Any()) { <tr><td colspan="9" style="text-align:center;padding:32px;color:var(--color-muted)">Inga kvittounderlag @(_sf.HasValue ? $"med status \"{Sw(_sf.Value)}\"" : "ännu").</td></tr> }
                    else
                    {
                        @foreach (var b in _batches)
                        {
                            var batch = b;
                            <tr style="cursor:pointer" @onclick='() => Nav.NavigateTo($"/receipts/{batch.Id}")'>
                                <td style="font-weight:500">@batch.Label</td>
                                <td style="font-size:.85rem">
                                    @if (batch.BatchCategoryIcon != null) { <span class="material-icons" style="font-size:1rem;vertical-align:middle;margin-right:3px">@batch.BatchCategoryIcon</span> }
                                    @batch.BatchCategoryName
                                </td>
                                <td style="font-size:.85rem;color:var(--color-muted)">@(batch.ProjectName ?? "–")</td>
                                <td style="text-align:right;font-size:.85rem;color:var(--color-muted)">@batch.LineCount st</td>
                                <td style="text-align:right;font-weight:600">@batch.TotalAmount.ToString("N2") kr</td>
                                <td><span class="badge @SBadge(batch.Status)" style="font-size:.72rem">@batch.StatusLabel</span></td>
                                <td style="font-size:.8rem;color:var(--color-muted)">@(batch.CreatedByEmail ?? "–")</td>
                                <td style="font-size:.8rem;color:var(--color-muted)">@batch.CreatedAt.ToString("yyyy-MM-dd")</td>
                                <td @onclick:stopPropagation style="display:flex;gap:2px">
                                    <button class="btn btn-ghost btn-icon btn-sm" title="Öppna" @onclick='() => Nav.NavigateTo($"/receipts/{batch.Id}")'>
                                        <span class="material-icons" style="font-size:.9rem">open_in_new</span>
                                    </button>
                                    <button class="btn btn-ghost btn-icon btn-sm" title="Ladda ned PDF" @onclick="() => ExportBatchPdfAsync(batch)" disabled="@_exporting">
                                        <span class="material-icons" style="font-size:.9rem">picture_as_pdf</span>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="mobile-page-shell">
    <div class="mobile-topbar">
        <span class="mobile-title">Kvittounderlag</span>
        @if (BudgetState.CanEdit) { <button class="mobile-icon-btn" @onclick='() => _showCreate = true'><span class="material-icons">add</span></button> }
    </div>
    <div class="mobile-chips" style="border-bottom:.5px solid var(--color-border)">
        <button class="mobile-chip @(_sf == null ? "active" : "")" @onclick="() => SetFilter(null)">Alla</button>
        @foreach (var s in Enum.GetValues<ReceiptBatchStatus>())
        { var status = s; <button class="mobile-chip @(_sf == status ? "active" : "")" @onclick="() => SetFilter(status)">@Sw(status)</button> }
    </div>
    <div class="mobile-page-scroll">
        @if (_loading) { <div style="text-align:center;padding:40px"><div class="spinner"></div></div> }
        else if (!_batches.Any()) { <div style="text-align:center;padding:48px 24px;color:var(--color-muted)"><span class="material-icons" style="font-size:2.5rem;display:block;margin-bottom:8px">receipt_long</span>Inga underlag</div> }
        else
        {
            @foreach (var b in _batches)
            {
                var batch = b;
                <div class="mobile-entry-card" @onclick='() => Nav.NavigateTo($"/receipts/{batch.Id}")'>
                    <div class="mobile-entry-card-header">
                        <div style="flex:1;min-width:0">
                            <div class="mobile-entry-card-title" style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis">
                                @if (batch.BatchCategoryIcon != null) { <span class="material-icons" style="font-size:.9rem;vertical-align:middle;margin-right:3px;color:var(--color-muted)">@batch.BatchCategoryIcon</span> }
                                @batch.Label
                            </div>
                            <div class="mobile-entry-card-meta">@batch.BatchCategoryName @if (batch.ProjectName != null) { <span>· @batch.ProjectName</span> } · @batch.LineCount kv. · @batch.CreatedAt.ToString("yyyy-MM-dd")</div>
                        </div>
                        <div style="text-align:right;flex-shrink:0;margin-left:10px">
                            <div class="mobile-entry-card-amount">@batch.TotalAmount.ToString("N0") kr</div>
                            <span class="badge @SBadge(batch.Status)" style="font-size:.67rem;margin-top:3px;display:inline-block">@batch.StatusLabel</span>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
    @if (BudgetState.CanEdit) { <button class="mobile-fab" @onclick='() => _showCreate = true'><span class="material-icons">add</span></button> }
</div>

@if (_showCreate)
{
    <div class="modal-overlay" @onclick='() => _showCreate = false'>
        <div class="modal" @onclick:stopPropagation>
            <div class="modal-header"><span class="modal-title">Nytt kvittounderlag</span></div>
            <div class="modal-body">
                <div class="form-group"><label class="form-label">Etikett *</label><input class="form-control" @bind="_newLabel" placeholder="T.ex. Konferensresa mars" /></div>
                <div class="form-group">
                    <label class="form-label">Kategori *</label>
                    <select class="form-control" @bind="_newCatId">
                        <option value="0">-- Välj kategori --</option>
                        @foreach (var c in _cats) { <option value="@c.Id">@c.Name</option> }
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick='() => _showCreate = false'>Avbryt</button>
                <button class="btn btn-primary" @onclick="CreateBatchAsync" disabled="@_creating">
                    @if (_creating) { <span class="spinner" style="width:14px;height:14px;border-width:2px"></span> } Skapa
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<ReceiptBatchDto>         _batches = new();
    private List<ReceiptBatchCategoryDto> _cats    = new();
    private ReceiptBatchStatus?           _sf;
    private string _newLabel = ""; private int _newCatId;
    private int    _page = 1, _pageSize = 25, _totalCount, _totalPages;
    private bool   _loading = true, _showCreate, _creating, _exporting;

    protected override async Task OnInitializedAsync()
    {
        BudgetState.StateChanged += OnStateChanged;
        _cats = await ReceiptSvc.GetCategoriesAsync(BudgetState.ActiveBudgetId) ?? new();
        await ReloadAsync();
    }

    public void Dispose() => BudgetState.StateChanged -= OnStateChanged;

    private void OnStateChanged() => InvokeAsync(async () =>
    {
        try { _cats = await ReceiptSvc.GetCategoriesAsync(BudgetState.ActiveBudgetId) ?? new(); _page = 1; await ReloadAsync(); }
        catch (Exception ex) { Toast.Error($"Laddningsfel: {ex.Message}"); }
        StateHasChanged();
    });

    private async Task ReloadAsync()
    {
        if (BudgetState.ActiveBudgetId <= 0) { _loading = false; return; }
        _loading = true;
        try { var r = await ReceiptSvc.GetAllAsync(BudgetState.ActiveBudgetId, _page, _pageSize, _sf); _batches = r?.Items ?? new(); _totalCount = r?.TotalCount ?? 0; _totalPages = r?.TotalPages ?? 1; }
        finally { _loading = false; }
    }

    private async Task SetFilter(ReceiptBatchStatus? s) { _sf = s; _page = 1; await ReloadAsync(); }

    private async Task ExportBatchPdfAsync(ReceiptBatchDto batch)
    {
        _exporting = true;
        try
        {
            var url      = ReceiptSvc.GetPdfUrl(BudgetState.ActiveBudgetId, batch.Id);
            var response = await Http.GetAsync(url);
            if (!response.IsSuccessStatusCode) { Toast.Error("Export misslyckades."); return; }
            var base64 = Convert.ToBase64String(await response.Content.ReadAsByteArrayAsync());
            var label  = batch.Label.Replace(" ", "_");
            await JS.InvokeVoidAsync("downloadFile", $"utlagg_{label}_{DateTime.Today:yyyyMMdd}.pdf", "application/pdf", base64);
        }
        catch (Exception ex) { Toast.Error($"Export: {ex.Message}"); }
        finally { _exporting = false; }
    }

    private async Task CreateBatchAsync()
    {
        if (string.IsNullOrWhiteSpace(_newLabel) || _newCatId == 0) return;
        _creating = true;
        try
        {
            var b = await ReceiptSvc.CreateAsync(BudgetState.ActiveBudgetId, new CreateReceiptBatchDto(_newLabel, _newCatId, null));
            if (b != null) { Toast.Success("Underlag skapat."); _showCreate = false; Nav.NavigateTo($"/receipts/{b.Id}"); }
        }
        catch (Exception ex) { Toast.Error(ex.Message); }
        finally { _creating = false; }
    }

    private static string SBadge(ReceiptBatchStatus s) => s switch
    { ReceiptBatchStatus.Draft => "badge-muted", ReceiptBatchStatus.Submitted => "badge", ReceiptBatchStatus.Approved => "badge-income", ReceiptBatchStatus.Rejected => "badge-expense", ReceiptBatchStatus.Reimbursed => "badge-primary", _ => "badge-muted" };
    private static string Sw(ReceiptBatchStatus s) => s switch
    { ReceiptBatchStatus.Draft => "Utkast", ReceiptBatchStatus.Submitted => "Inskickad", ReceiptBatchStatus.Approved => "Godkänd", ReceiptBatchStatus.Rejected => "Avslagen", ReceiptBatchStatus.Reimbursed => "Utbetald", _ => s.ToString() };
}
