    // INLINE LIST TASKS
    // ─────────────────────────────────────────────────────────────────────────

    private void AddNewListItem() => _newListItems.Add("");
    private void RemoveNewListItem(int idx) { if (idx >= 0 && idx < _newListItems.Count) _newListItems.RemoveAt(idx); }

    // ─────────────────────────────────────────────────────────────────────────
    // LIST / NOTE DETAIL MODAL
    // ─────────────────────────────────────────────────────────────────────────

    private void OpenListDetail(UserListDto list)
    {
        _activeList         = list;
        _activeNewItemText  = "";
        _activeNewItemQty   = 1;
        _activeNewItemPrice = 0;
        _noteEditMode       = false;
    }

    private void CloseListDetail() { _activeList = null; _noteEditMode = false; }

    private void ToggleNoteEdit()
    {
        if (_activeList == null) return;
        _noteEditMode = !_noteEditMode;
        if (_noteEditMode)
        {
            _editActiveTitle   = _activeList.Name;
            _editActiveContent = _activeList.Content ?? "";
            _editActiveTags    = _activeList.Tags ?? "";
        }
    }

    private async Task SaveActiveListEditAsync()
    {
        if (_activeList == null) return;
        _noteEditSaving = true;
        try
        {
            var dto = new CreateListDto(_editActiveTitle.Trim(), _activeList.ListType, _activeList.Description, _editActiveContent, string.IsNullOrWhiteSpace(_editActiveTags) ? null : _editActiveTags, _activeList.Scope, _activeList.Visibility);
            var updated = await ListSvc.UpdateAsync(BudgetState.ActiveBudgetId, _activeList.Id, dto);
            if (updated != null) _activeList = updated;
            var idx = _lists.FindIndex(l => l.Id == _activeList!.Id);
            if (idx >= 0 && updated != null) _lists[idx] = updated;
            _noteEditMode = false;
            Toast.Success("Sparat.");
        }
        catch (Exception ex) { Toast.Error(ex.Message); }
        finally { _noteEditSaving = false; }
    }

    private async Task DeleteListAsync(UserListDto list)
    {
        if (_confirmDialog == null || !await _confirmDialog.ShowAsync()) return;
        try
        {
            await ListSvc.DeleteAsync(BudgetState.ActiveBudgetId, list.Id);
            _lists.RemoveAll(l => l.Id == list.Id);
            if (_activeList?.Id == list.Id) _activeList = null;
            Toast.Success("Borttagen.");
        }
        catch (Exception ex) { Toast.Error(ex.Message); }
    }

    private async Task ToggleActiveListItemAsync(int itemId)
    {
        if (_activeList is null) return;
        try
        {
            var upd = await ListSvc.ToggleItemAsync(BudgetState.ActiveBudgetId, _activeList.Id, itemId);
            if (upd != null)
            {
                var i = _activeList.Items.FirstOrDefault(x => x.Id == itemId);
                if (i != null) { i.IsChecked = upd.IsChecked; i.CompletedAt = upd.CompletedAt; }
                _activeList.CheckedItems = _activeList.Items.Count(x => x.IsChecked);
                var g = _lists.FirstOrDefault(x => x.Id == _activeList.Id);
                if (g != null) { var gi = g.Items.FirstOrDefault(x => x.Id == itemId); if (gi != null) { gi.IsChecked = upd.IsChecked; gi.CompletedAt = upd.CompletedAt; } g.CheckedItems = g.Items.Count(x => x.IsChecked); }
            }
        }
        catch (Exception ex) { Toast.Error(ex.Message); }
    }

    private async Task DeleteActiveListItemAsync(int itemId)
    {
        if (_activeList is null) return;
        try
        {
            await ListSvc.DeleteItemAsync(BudgetState.ActiveBudgetId, _activeList.Id, itemId);
            _activeList.Items.RemoveAll(x => x.Id == itemId);
            _activeList.TotalItems = _activeList.Items.Count;
            _activeList.CheckedItems = _activeList.Items.Count(x => x.IsChecked);
            var g = _lists.FirstOrDefault(x => x.Id == _activeList.Id);
            if (g != null) { g.Items.RemoveAll(x => x.Id == itemId); g.TotalItems = g.Items.Count; g.CheckedItems = g.Items.Count(x => x.IsChecked); }
        }
        catch (Exception ex) { Toast.Error(ex.Message); }
    }

    private async Task AddActiveListItemAsync()
    {
        if (_activeList is null) return;
        var textToAdd = _activeList.ListType == ListType.Shopping
            ? FormatShoppingItem(_activeNewItemQty, _activeNewItemPrice, _activeNewItemText)
            : _activeNewItemText;
        if (string.IsNullOrWhiteSpace(_activeNewItemText)) return;
        try
        {
            var item = await ListSvc.AddItemAsync(BudgetState.ActiveBudgetId, _activeList.Id, new CreateListItemDto(textToAdd.Trim()));
            if (item != null)
            {
                _activeList.Items.Add(item); _activeList.TotalItems++;
                var g = _lists.FirstOrDefault(x => x.Id == _activeList.Id);
                if (g != null) { g.Items.Add(item); g.TotalItems++; }
                _activeNewItemText = ""; _activeNewItemQty = 1; _activeNewItemPrice = 0;
            }
        }
        catch (Exception ex) { Toast.Error(ex.Message); }
    }

    private async Task OnActiveListItemKeyDown(KeyboardEventArgs e) { if (e.Key == "Enter") await AddActiveListItemAsync(); }

    private async Task ClearCheckedAsync()
    {
        if (_activeList is null) return;
        try
        {
            var upd = await ListSvc.ClearCheckedAsync(BudgetState.ActiveBudgetId, _activeList.Id);
            if (upd != null)
            {
                _activeList = upd;
                var g = _lists.FirstOrDefault(x => x.Id == upd.Id);
                if (g != null) { var idx = _lists.IndexOf(g); _lists[idx] = upd; }
            }
        }
        catch (Exception ex) { Toast.Error(ex.Message); }
    }

    private async Task OnListItemKeyDown(KeyboardEventArgs e, int listId) { if (e.Key == "Enter") await AddListItemInlineAsync(listId); }
    private async Task AddListItemInlineAsync(int listId)
    { if (!_newItemText.TryGetValue(listId, out var txt) || string.IsNullOrWhiteSpace(txt)) return; try { var item = await ListSvc.AddItemAsync(BudgetState.ActiveBudgetId, listId, new CreateListItemDto(txt.Trim())); if (item != null) { var l = _lists.FirstOrDefault(x => x.Id == listId); if (l != null) { l.Items.Add(item); l.TotalItems++; } _newItemText[listId] = ""; StateHasChanged(); } } catch (Exception ex) { Toast.Error(ex.Message); } }

    // ─────────────────────────────────────────────────────────────────────────
    // SHOPPING ITEM HELPERS
    // ─────────────────────────────────────────────────────────────────────────

    private static (int qty, decimal price, string name) ParseShoppingItem(string text)
    {
        var parts = text.Split('|');
        if (parts.Length >= 3 && int.TryParse(parts[0], out var q) && decimal.TryParse(parts[1], System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var p))
            return (q, p, parts[2]);
        return (1, 0, text);
    }
    private static string FormatShoppingItem(int qty, decimal price, string name)
        => $"{qty}|{price.ToString(System.Globalization.CultureInfo.InvariantCulture)}|{name}";

    // ─────────────────────────────────────────────────────────────────────────
    // JOURNAL TABLE
    // ─────────────────────────────────────────────────────────────────────────

    RenderFragment JournalTable() =>
        @<table style="width:100%;border-collapse:collapse" class="quickgrid">
            <thead>
                <tr>
                    <th style="width:32px">@if (BudgetState.CanEdit) { <input type="checkbox" checked="@_selectAll" @onchange="ToggleAll" /> }</th>
                    <th style="cursor:pointer;width:100px" @onclick='() => SetSort("Date")'>Datum @SortIndicator("Date")</th>
                    <th style="width:92px">Typ</th>
                    <th style="cursor:pointer" @onclick='() => SetSort("Description")'>Beskrivning @SortIndicator("Description")</th>
                    <th style="width:140px">Kategori / Taggar</th>
                    <th style="width:100px">Projekt</th>
                    <th style="width:90px">Status</th>
                    <th style="cursor:pointer;text-align:right;width:105px" @onclick='() => SetSort("Amount")'>Belopp @SortIndicator("Amount")</th>
                    <th style="width:90px"></th>
                </tr>
            </thead>
            <tbody>
                @if (!_entries.Any() && (!ShowLists || !_lists.Any()))
                { <tr><td colspan="9" style="text-align:center;padding:40px;color:var(--color-muted)"><span class="material-icons" style="display:block;font-size:2rem;margin-bottom:8px;opacity:.4">inbox</span>Inga poster hittades.</td></tr> }

                @* ─── Lists / Notes rows ──────────────────────────────────────── *@
                @if (ShowLists)
                {
                    @foreach (var list in _lists)
                    {
                        var ul = list;
                        <tr style="background:var(--color-bg)">
                            <td></td>
                            <td style="font-size:.8rem;color:var(--color-muted)">@ul.UpdatedAt.ToString("yyyy-MM-dd")</td>
                            <td><span class="badge badge-muted" style="font-size:.7rem">@(ul.IsNote ? "Anteckning" : ListTypeLabel(ul.ListType))</span></td>
                            <td>
                                <span style="font-size:.875rem;font-weight:500;cursor:pointer;color:var(--color-primary)" @onclick="() => OpenListDetail(ul)" title="Klicka för att öppna / redigera">@ul.Name</span>
                                @if (ul.IsNote && ul.Content != null)
                                { <div style="font-size:.75rem;color:var(--color-muted);max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">@ul.Content</div> }
                                else if (!ul.IsNote)
                                { <span style="font-size:.75rem;color:var(--color-muted);margin-left:6px">@ul.CheckedItems/@ul.TotalItems klara</span> }
                            </td>
                            <td style="font-size:.78rem;color:var(--color-primary)">@(ul.Tags ?? "–")</td>
                            <td colspan="2"></td>
                            <td style="text-align:right">
                                @if (!ul.IsNote && ul.TotalItems > 0)
                                { var pct = (int)(100.0 * ul.CheckedItems / ul.TotalItems); <div style="width:60px;height:6px;background:var(--color-border);border-radius:3px;display:inline-block;vertical-align:middle;overflow:hidden"><div style="height:100%;width:@pct%;background:var(--color-income);border-radius:3px"></div></div> }
                            </td>
                            <td @onclick:stopPropagation style="display:flex;gap:2px;align-items:center">
                                <button class="btn btn-ghost btn-icon btn-sm" title="Öppna / redigera" @onclick="() => OpenListDetail(ul)"><span class="material-icons" style="font-size:.9rem">open_in_new</span></button>
                                @if (BudgetState.CanEdit)
                                { <button class="btn btn-ghost btn-icon btn-sm" title="Ta bort" @onclick="() => DeleteListAsync(ul)"><span class="material-icons" style="font-size:.85rem;color:var(--color-expense)">delete</span></button> }
                            </td>
                        </tr>
                    }
                }

                @* ─── Journal entries ─────────────────────────────────────────── *@
                @foreach (var entry in _entries)
                {
                    var e = entry; var isSel = _selectedIds.Contains(e.SourceId);
                    var expandKey = $"{e.EntryType}-{e.SourceId}"; var isExpRow = _expanded.Contains(expandKey);
                    <tr class="@(isSel ? "selected" : "")">
                        <td @onclick:stopPropagation>@if (BudgetState.CanEdit && e.EntryType == JournalEntryType.Transaction) { <input type="checkbox" checked="@isSel" @onchange="() => ToggleRow(e.SourceId)" /> }</td>
                        <td style="font-size:.8rem;color:var(--color-muted)">@e.Date.ToString("yyyy-MM-dd")</td>
                        <td><span class="badge @TypeBadge(e.EntryType)" style="font-size:.7rem">@e.TypeLabel</span></td>
                        <td>
                            <span style="font-size:.875rem">@e.Description</span>
                            @if (e.HasDetail && e.EntryType == JournalEntryType.Transaction) { <span class="badge badge-muted" style="margin-left:4px;font-size:.67rem" title="Har kontering">K</span> }
                            @if (e.ReceiptLineCount > 0) { <span class="badge badge-muted" style="margin-left:4px;font-size:.67rem">@e.ReceiptLineCount kv.</span> }
                            @if (e.MetaLine != null) { <div style="font-size:.75rem;color:var(--color-muted)">@e.MetaLine</div> }
                        </td>
                        <td style="font-size:.8rem;color:var(--color-muted)">@(e.CategoryName ?? "–")</td>
                        <td style="font-size:.8rem;color:var(--color-muted)">@(e.ProjectName ?? "–")</td>
                        <td>@if (e.Status != null) { <span class="badge @StatusBadge(e.Status)" style="font-size:.7rem">@e.Status</span> }</td>
                        <td style="text-align:right"><span class="@(e.Amount >= 0 ? "amount-income" : "amount-expense")" style="font-size:.875rem;font-weight:600">@AmountStr(e)</span></td>
                        <td @onclick:stopPropagation style="display:flex;gap:2px;align-items:center">
                            @if (e.EntryType == JournalEntryType.Transaction && e.HasDetail)
                            { <button class="btn btn-ghost btn-icon btn-sm" title="Visa kontering" @onclick="() => ToggleExpand(expandKey, e)"><span class="material-icons" style="font-size:.9rem">@(isExpRow ? "expand_less" : "expand_more")</span></button> }
                            @if (e.EntryType == JournalEntryType.ReceiptBatch)
                            {
                                <button class="btn btn-ghost btn-icon btn-sm" title="Visa kvittolinjer" @onclick="() => ToggleExpand(expandKey, e)"><span class="material-icons" style="font-size:.9rem">@(isExpRow ? "expand_less" : "expand_more")</span></button>
                                <button class="btn btn-ghost btn-icon btn-sm" title="Öppna underlag" @onclick='() => Nav.NavigateTo($"/receipts/{e.SourceId}")'><span class="material-icons" style="font-size:.9rem">open_in_new</span></button>
                            }
                            @if (BudgetState.CanEdit && e.EntryType == JournalEntryType.Transaction)
                            {
                                @if (_editingId == e.SourceId) { <span class="spinner" style="width:14px;height:14px;border-width:2px;margin:7px 4px"></span> }
                                else { <button class="btn btn-ghost btn-icon btn-sm" title="Redigera transaktion" @onclick="() => EditEntryAsync(e)"><span class="material-icons" style="font-size:.9rem">edit</span></button> }
                            }
                            @if (BudgetState.CanEdit && e.EntryType == JournalEntryType.Milersattning)
                            { <button class="btn btn-ghost btn-icon btn-sm" title="Ta bort milersättning" @onclick="() => DeleteMiAsync(e.SourceId)"><span class="material-icons" style="font-size:.85rem;color:var(--color-expense)">delete</span></button> }
                            @if (BudgetState.CanEdit && e.EntryType == JournalEntryType.Vab)
                            { <button class="btn btn-ghost btn-icon btn-sm" title="Ta bort VAB" @onclick="() => DeleteVabAsync(e.SourceId)"><span class="material-icons" style="font-size:.85rem;color:var(--color-expense)">delete</span></button> }
                        </td>
                    </tr>

                    @* Expand: Kontering rows *@
                    @if (isExpRow && e.EntryType == JournalEntryType.Transaction && e.KonteringRows.Any())
                    {
                        @foreach (var k in e.KonteringRows)
                        { <tr style="background:var(--color-bg)"><td></td><td></td><td style="font-size:.75rem;color:var(--color-muted)">↳ @k.KontoNr</td><td style="font-size:.75rem;color:var(--color-muted)">@(k.Description ?? "")</td><td style="font-size:.75rem;color:var(--color-muted)">@(k.CostCenter ?? "")</td><td colspan="2"></td><td style="text-align:right;font-size:.8rem;color:var(--color-muted)">@k.Amount.ToString("N2") kr</td><td></td></tr> }
                    }

                    @* Expand: Receipt lines *@
                    @if (isExpRow && e.EntryType == JournalEntryType.ReceiptBatch)
                    {
                        @if (_receiptCache.TryGetValue(e.SourceId, out var cachedBatch))
                        {
                            @if (!cachedBatch.Lines.Any())
                            { <tr style="background:var(--color-bg)"><td colspan="9" style="text-align:center;font-size:.8rem;color:var(--color-muted);padding:8px">Inga kvittolinjer.</td></tr> }
                            @foreach (var line in cachedBatch.Lines.OrderBy(l => l.SequenceNumber))
                            {
                                <tr style="background:var(--color-bg)">
                                    <td></td>
                                    <td style="font-size:.78rem;color:var(--color-muted)">@line.Date.ToString("yyyy-MM-dd")</td>
                                    <td><span style="font-family:monospace;font-size:.73rem;color:var(--color-primary)">@line.ReferenceCode</span></td>
                                    <td style="font-size:.82rem">@(line.Vendor ?? "–")@if(line.Description!=null){<span style="color:var(--color-muted)"> · @line.Description</span>}</td>
                                    <td colspan="3"></td>
                                    <td style="text-align:right;font-size:.82rem;font-weight:600">@line.Amount.ToString("N2") kr</td>
                                    <td></td>
                                </tr>
                            }
                            <tr style="background:var(--color-bg);border-top:.5px solid var(--color-border)">
                                <td colspan="7"></td>
                                <td style="text-align:right;font-size:.82rem;font-weight:600;color:var(--color-expense)">Σ @cachedBatch.Lines.Sum(l => l.Amount).ToString("N2") kr</td>
                                <td></td>
                            </tr>
                        }
                        else
                        { <tr style="background:var(--color-bg)"><td colspan="9" style="text-align:center;font-size:.8rem;padding:8px"><div class="spinner" style="width:14px;height:14px;border-width:2px;display:inline-block"></div></td></tr> }
                    }
                }
            </tbody>
        </table>

    private string SortIndicator(string col) => Filter.Query.SortBy != col ? "" : Filter.Query.SortDir == "asc" ? " ▲" : " ▼";

