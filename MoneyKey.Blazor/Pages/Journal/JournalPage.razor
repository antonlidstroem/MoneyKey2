    // ─────────────────────────────────────────────────────────────────────────

    private void OnVabJobChanged()
    {
        if (_vabJobId <= 0) return;
        var job = _jobs.FirstOrDefault(j => j.Id == _vabJobId);
        if (job?.GrossAmount > 0)
        {
            _vabSgi = job.GrossAmount.Value * 12;
            _vabDailyBenefit = VabService.CalculateDailyBenefit(_vabSgi);
        }
    }

    private void OnVabSgiChanged()
    { if (_vabSgi > 0) _vabDailyBenefit = VabService.CalculateDailyBenefit(_vabSgi); }

