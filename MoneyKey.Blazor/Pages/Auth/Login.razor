@page "/login"
@layout EmptyLayout
@inject AuthService AuthSvc
@inject NavigationManager Nav

<div style="min-height:100vh;display:flex;align-items:center;justify-content:center;background:var(--color-bg)">
    <div style="width:100%;max-width:380px;padding:24px">
        <div style="text-align:center;margin-bottom:32px">
            <img src="images/moneykey-logo.png"
                 alt="MoneyKey"
                 style="max-width: 30%; height: auto; display: block; margin: 20px auto 0 auto;" />
           
                 <div class="sidebar-logo" style="text-align: center;">
                <h1 style="font-size:1.8rem;font-weight:700;color: black; margin: 0;">Money<span>Key</span></h1>
                
                <p style="color:var(--color-muted);font-size:.9rem;margin-top:4px">Logga in på ditt konto</p>
            </div>
        </div>
        <div class="card">
            @if (!string.IsNullOrEmpty(_error))
            {
                <div style="background:var(--color-expense-bg);color:var(--color-expense);padding:10px 14px;border-radius:8px;font-size:.875rem;margin-bottom:14px">@_error</div>
            }
            <div class="form-group">
                <label class="form-label">E-postadress</label>
                <input class="form-control" type="email" @bind="_email" placeholder="din@email.se" />
            </div>
            <div class="form-group">
                <label class="form-label">Lösenord</label>
                <input class="form-control" type="password" @bind="_password" @onkeydown="OnKeyDown" />
            </div>
            <button class="btn btn-primary" style="width:100%;justify-content:center;margin-top:8px" @onclick="LoginAsync" disabled="@_loading">
                @if (_loading) { <span class="spinner" style="width:14px;height:14px;border-width:2px"></span> }
                Logga in
            </button>
        </div>
        <p style="text-align:center;margin-top:16px;font-size:.875rem;color:var(--color-muted)">
            Inget konto? <a href="/register" style="color:var(--color-primary)">Skapa konto</a>
        </p>
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "returnUrl")] private string? ReturnUrl { get; set; }

    private string _email = "", _password = "", _error = "";
    private bool _loading;

    private async Task LoginAsync()
    {
        _error = ""; _loading = true;
        try
        {
            var result = await AuthSvc.LoginAsync(new LoginDto(_email, _password));
            if (result != null) Nav.NavigateTo(!string.IsNullOrWhiteSpace(ReturnUrl) ? ReturnUrl : "/");
            else _error = "Inloggningen misslyckades.";
        }
        catch { _error = "Kunde inte ansluta till servern."; }
        finally { _loading = false; }
    }

    private async Task OnKeyDown(KeyboardEventArgs e) { if (e.Key == "Enter") await LoginAsync(); }
}
