@page "/settings"
@attribute [Authorize]
@inject BudgetService BudgetSvc
@inject ToastService Toast
@inject BudgetState BudgetState
@inject AdminApiService AdminSvc
@inject JwtAuthenticationStateProvider AuthProvider
@inject IConfiguration Config

<div class="desktop-page-wrapper">
    <div class="page-header"><span class="page-title">Inställningar</span></div>
    <div class="page-content" style="max-width:600px;display:flex;flex-direction:column;gap:16px">
        @SettingsBody()
    </div>
</div>

<div class="mobile-page-shell">
    <div class="mobile-topbar"><span class="mobile-title">Inställningar</span></div>
    <div class="mobile-page-scroll">@SettingsBody()</div>
</div>

@code {
    private string _budgetName = "", _budgetDescription = "", _inviteEmail = "", _saveError = "";
    private BudgetMemberRole _inviteRole = BudgetMemberRole.Editor;
    private bool _saving, _inviting, _signalREnabled = true, _signalRLoading, _signalRSaving;

    private bool IsSuperAdmin =>
        !string.IsNullOrEmpty(Config["AdminSetup:Email"]) &&
        string.Equals(JwtAuthenticationStateProvider.CurrentUser?.Email, Config["AdminSetup:Email"], StringComparison.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        _budgetName = BudgetState.ActiveBudgetName;
        if (IsSuperAdmin)
        {
            _signalRLoading = true;
            try { _signalREnabled = await AdminSvc.GetSignalRStatusAsync(); }
            finally { _signalRLoading = false; }
        }
    }

    private async Task SaveBudgetAsync()
    {
        if (string.IsNullOrWhiteSpace(_budgetName)) { _saveError = "Budgetnamnet får inte vara tomt."; return; }
        _saveError = ""; _saving = true;
        try
        {
            await BudgetSvc.UpdateAsync(BudgetState.ActiveBudgetId, new UpdateBudgetDto(_budgetName.Trim(), _budgetDescription));
            BudgetState.UpdateActiveBudgetName(_budgetName.Trim());
            Toast.Success("Budget uppdaterad.");
        }
        catch (Exception ex) { _saveError = ex.Message; }
        finally { _saving = false; }
    }

    private async Task InviteAsync()
    {
        if (string.IsNullOrWhiteSpace(_inviteEmail)) return;
        _inviting = true;
        try { await BudgetSvc.InviteAsync(BudgetState.ActiveBudgetId, new InviteMemberDto(_inviteEmail, _inviteRole)); Toast.Success("Inbjudan skickad."); _inviteEmail = ""; }
        catch (Exception ex) { Toast.Error(ex.Message); }
        finally { _inviting = false; }
    }

    private async Task ToggleSignalRAsync()
    {
        _signalRSaving = true;
        try
        {
            _signalREnabled = await AdminSvc.ToggleSignalRAsync(!_signalREnabled);
            Toast.Success(_signalREnabled ? "SignalR aktiverat." : "SignalR inaktiverat.");
        }
        catch (Exception ex) { Toast.Error(ex.Message); }
        finally { _signalRSaving = false; }
    }

    private RenderFragment SettingsBody() =>
        @<div style="display:flex;flex-direction:column;gap:16px">
            <div class="card">
                <div class="card-title"><span class="material-icons">manage_accounts</span> Budget</div>
                <div class="form-group"><label class="form-label">Budgetnamn</label><input class="form-control" @bind="_budgetName" /></div>
                <div class="form-group"><label class="form-label">Beskrivning</label><input class="form-control" @bind="_budgetDescription" placeholder="Valfri beskrivning..." /></div>
                @if (!string.IsNullOrEmpty(_saveError)) { <div style="color:var(--color-expense);font-size:.85rem;margin-bottom:8px">@_saveError</div> }
                <button class="btn btn-primary btn-sm" @onclick="SaveBudgetAsync" disabled="@_saving">
                    @if (_saving) { <span class="spinner" style="width:14px;height:14px;border-width:2px"></span> }
                    Spara
                </button>
            </div>

            @if (BudgetState.IsOwner)
            {
                <div class="card">
                    <div class="card-title"><span class="material-icons">group_add</span> Bjud in användare</div>
                    <div class="form-group"><label class="form-label">E-postadress</label><input class="form-control" type="email" @bind="_inviteEmail" placeholder="anvan@example.com" /></div>
                    <div class="form-group">
                        <label class="form-label">Roll</label>
                        <select class="form-control" @bind="_inviteRole">
                            <option value="@BudgetMemberRole.Viewer">Läsare</option>
                            <option value="@BudgetMemberRole.Editor">Redigerare</option>
                            <option value="@BudgetMemberRole.Auditor">Revisor</option>
                            <option value="@BudgetMemberRole.Owner">Ägare</option>
                        </select>
                    </div>
                    <button class="btn btn-primary btn-sm" @onclick="InviteAsync" disabled="@_inviting">
                        @if (_inviting) { <span class="spinner" style="width:14px;height:14px;border-width:2px"></span> }
                        <span class="material-icons" style="font-size:.9rem">send</span> Skicka inbjudan
                    </button>
                </div>
            }

            @if (IsSuperAdmin)
            {
                <div class="card">
                    <div class="card-title"><span class="material-icons">hub</span> SignalR (Superadmin)</div>
                    <p style="font-size:.85rem;color:var(--color-muted);margin-bottom:14px">
                        Inaktivera SignalR för att minska CPU-förbrukning när realtidsuppdateringar inte behövs.
                        Applikationen fungerar normalt utan SignalR.
                    </p>
                    @if (_signalRLoading)
                    {
                        <div class="spinner" style="width:20px;height:20px;border-width:2px"></div>
                    }
                    else
                    {
                        <div style="display:flex;align-items:center;gap:12px">
                            <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-size:.875rem">
                                <input type="checkbox" checked="@_signalREnabled" @onchange="ToggleSignalRAsync" disabled="@_signalRSaving" />
                                SignalR @(_signalREnabled ? "aktiverat" : "inaktiverat")
                            </label>
                            @if (_signalRSaving) { <span class="spinner" style="width:14px;height:14px;border-width:2px"></span> }
                        </div>
                    }
                </div>
            }
        </div>;
}
