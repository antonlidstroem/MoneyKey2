@page "/settings"
@attribute [Authorize]
@inject BudgetService BudgetSvc
@inject ToastService Toast
@inject BudgetState BudgetState
@inject SubscriptionApiService SubSvc
@inject InvitationApiService InvSvc
@inject AdminApiService AdminSvc
@inject JwtAuthenticationStateProvider AuthProvider
@inject IConfiguration Config
@inject NavigationManager Nav
@inject HttpClient Http

<div class="desktop-page-wrapper">
    <div class="page-header"><span class="page-title">Inställningar</span></div>
    <div class="page-content" style="max-width:640px;display:flex;flex-direction:column;gap:16px">
        @@SettingsContent
    </div>
</div>

<div class="mobile-page-shell">
    <div class="mobile-topbar"><span class="mobile-title">Inställningar</span></div>
    <div class="mobile-page-scroll">
        @@SettingsContent
    </div>
</div>

@code {
    private string _budgetName = "", _budgetDescription = "", _inviteEmail = "", _inviteDisplayName = "", _saveError = "";
    private List<string> _displayNameSuggestions = new();
    private string _transferTo = "";
    private bool _transferring;
    private bool _showDeleteConfirm, _deleting;
    private string _deleteConfirmText = "";
    private System.Threading.Timer? _searchDebounce;
    private string _newBudgetName = "", _newBudgetDescription = "", _newBudgetError = "";
    private BudgetMemberRole _inviteRole = BudgetMemberRole.Editor;
    private bool _saving, _inviting, _signalREnabled = true, _signalRLoading, _signalRSaving;
    private bool _creatingBudget;
    private HashSet<string> _disabledFeatures = new(StringComparer.OrdinalIgnoreCase);
    private bool _featuresLoading;

    private static readonly (string Key, string Label, string Icon)[] AllFeatures =
    {
        ("Milersattning", "Milersättning",    "directions_car"),
        ("Vab",           "VAB",              "child_care"),
        ("Receipts",      "Kvittounderlag",   "receipt_long"),
        ("Lists",         "Listor & anteckn.","checklist"),
        ("Kontering",     "Kontering",        "account_tree"),
        ("Export",        "Export (PDF/XLS)", "download"),
        ("TimeTracking",  "Tidrapportering", "schedule"),
        ("Loans",         "Lån & Krediter",   "account_balance"),
        ("Insurance",     "Försäkringar",     "security"),
        ("SickLeave",     "Sjukfrånvaro",     "sick")
    };

    private bool IsSuperAdmin =>
        !string.IsNullOrEmpty(Config["AdminSetup:Email"]) &&
        string.Equals(AuthProvider.GetCurrentUser()?.Email,
            Config["AdminSetup:Email"], StringComparison.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        _budgetName = BudgetState.ActiveBudgetName;
        await LoadFeaturesAsync();
        if (IsSuperAdmin)
        {
            _signalRLoading = true;
            try
            {
                var res = await AdminSvc.GetSignalRStatusAsync();
                _signalREnabled = res?.Enabled ?? false; // FIX: CS0029 - mappar objekt till bool
            }
            finally { _signalRLoading = false; }
        }
    }

    private async Task LoadFeaturesAsync()
    {
        if (BudgetState.ActiveBudgetId <= 0) return;
        _featuresLoading = true;
        try
        {
            var disabled = await BudgetSvc.GetDisabledFeaturesAsync(BudgetState.ActiveBudgetId) ?? new();
            _disabledFeatures = new HashSet<string>(disabled, StringComparer.OrdinalIgnoreCase);
            BudgetState.SetFeatures(_disabledFeatures);
        }
        finally { _featuresLoading = false; }
    }

    private async Task ToggleFeatureAsync(string key, bool nowEnabled)
    {
        try
        {
            await BudgetSvc.SetFeatureAsync(BudgetState.ActiveBudgetId, key, nowEnabled);
            if (nowEnabled) _disabledFeatures.Remove(key);
            else _disabledFeatures.Add(key);
            BudgetState.SetFeatures(_disabledFeatures);
            Toast.Success($"{key} {(nowEnabled ? "aktiverat" : "inaktiverat")}.");
        }
        catch (Exception ex) { Toast.Error(ex.Message); }
    }

    private async Task SaveBudgetAsync()
    {
        if (string.IsNullOrWhiteSpace(_budgetName)) { _saveError = "Budgetnamnet får inte vara tomt."; return; }
        _saveError = ""; _saving = true;
        try
        {
            await BudgetSvc.UpdateAsync(BudgetState.ActiveBudgetId, new UpdateBudgetDto(_budgetName.Trim(), _budgetDescription));
            BudgetState.UpdateActiveBudgetName(_budgetName.Trim());
            Toast.Success("Budget uppdaterad.");
        }
        catch (Exception ex) { _saveError = ex.Message; }
        finally { _saving = false; }
    }

    private async Task CreateBudgetAsync()
    {
        if (string.IsNullOrWhiteSpace(_newBudgetName)) { _newBudgetError = "Ange ett budgetnamn."; return; }
        _newBudgetError = ""; _creatingBudget = true;
        try
        {
            var created = await BudgetSvc.CreateAsync(new CreateBudgetDto(_newBudgetName.Trim(), _newBudgetDescription));
            if (created != null)
            {
                Toast.Success($"Budget \"{created.Name}\" skapad.");
                _newBudgetName = ""; _newBudgetDescription = "";
                var budgets = await BudgetSvc.GetMyBudgetsAsync();
                if (budgets != null) BudgetState.SetBudgets(budgets);
            }
        }
        catch (Exception ex) { _newBudgetError = ex.Message; }
        finally { _creatingBudget = false; }
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        var q = e.Value?.ToString() ?? "";
        _inviteDisplayName = q;
        _searchDebounce?.Dispose();
        if (q.Length < 2) { _displayNameSuggestions.Clear(); StateHasChanged(); return; }
        _searchDebounce = new System.Threading.Timer(async _ =>
        {
            var results = await SubSvc.SearchUsersAsync(q);
            await InvokeAsync(() => { _displayNameSuggestions = results; StateHasChanged(); });
        }, null, 300, System.Threading.Timeout.Infinite);
    }

    private void SelectSuggestion(string name) { _inviteDisplayName = name; _displayNameSuggestions.Clear(); }

    private async Task InviteAsync()
    {
        if (string.IsNullOrWhiteSpace(_inviteDisplayName)) return;
        _inviting = true;
        try
        {
            var err = await InvSvc.SendInvitationAsync(BudgetState.ActiveBudgetId, _inviteDisplayName, _inviteRole);
            if (err != null) Toast.Error(err);
            else
            {
                Toast.Success($"Inbjudan skickad till {_inviteDisplayName}.");
                _inviteDisplayName = "";
                _displayNameSuggestions.Clear();
            }
        }
        catch (Exception ex) { Toast.Error(ex.Message); }
        finally { _inviting = false; }
    }

    private async Task ToggleSignalRAsync()
    {
        _signalRSaving = true;
        try
        {
            var res = await AdminSvc.ToggleSignalRAsync(!_signalREnabled);
            _signalREnabled = res?.Enabled ?? !_signalREnabled;
            Toast.Success(_signalREnabled ? "SignalR aktiverat." : "SignalR inaktiverat.");
        }
        catch (Exception ex) { Toast.Error(ex.Message); }
        finally { _signalRSaving = false; }
    }

    private async Task DeleteAccountAsync()
    {
        if (_deleteConfirmText != "RADERA") return;
        _deleting = true;
        try
        {
            var r = await Http.DeleteAsync("api/auth/account");
            if (r.IsSuccessStatusCode)
            {
                await AuthProvider.LogoutAsync();
                Nav.NavigateTo("/login");
            }
            else Toast.Error("Radering misslyckades. Försök igen.");
        }
        catch (Exception ex) { Toast.Error(ex.Message); }
        finally { _deleting = false; _showDeleteConfirm = false; }
    }

    // Samlar all HTML i en RenderFragment för att undvika duplication mellan Desktop/Mobil
    private RenderFragment SettingsContent =>
    @<div style="display:flex;flex-direction:column;gap:16px">
        <div class="card">
            <div class="card-title"><span class="material-icons">manage_accounts</span> Budget — @BudgetState.ActiveBudgetName</div>
            <div class="form-group"><label class="form-label">Budgetnamn</label><input class="form-control" @bind="_budgetName" /></div>
            <div class="form-group"><label class="form-label">Beskrivning</label><input class="form-control" @bind="_budgetDescription" placeholder="Valfri beskrivning..." /></div>
            @if (!string.IsNullOrEmpty(_saveError))
            {
                <div style="color:var(--color-expense);font-size:.85rem;margin-bottom:8px">@_saveError</div>
            }
            <button class="btn btn-primary btn-sm" @onclick="SaveBudgetAsync" disabled="@_saving">
                @if (_saving)
                {
                    <span class="spinner" style="width:14px;height:14px;border-width:2px"></span>
                }
                Spara
            </button>
        </div>

        @if (BudgetState.IsOwner)
        {
            <div class="card">
                <div class="card-title"><span class="material-icons">toggle_on</span> Funktioner</div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
                    @foreach (var (key, label, icon) in AllFeatures)
                    {
                        var k = key; var enabled = !_disabledFeatures.Contains(k);
                        <label style="display:flex;align-items:center;gap:10px;padding:10px;border:1px solid var(--color-border);border-radius:8px;cursor:pointer">
                            <input type="checkbox" checked="@enabled" @onchange="e => ToggleFeatureAsync(k, e.Value is true)" />
                            <span class="material-icons" style="font-size:1.1rem">@icon</span>
                            <span style="font-size:.875rem">@label</span>
                        </label>
                    }
                </div>
            </div>

            <div class="card">
                <div class="card-title"><span class="material-icons">group_add</span> Bjud in</div>
                <div class="form-group">
                    <label class="form-label">Smeknamn</label>
                    <div style="position:relative">
                        @* FIX: RZ10008 - Tog bort @bind:event="oninput" för att tillåta manuell hantering i OnSearchInput *@
                        <input class="form-control" value="@_inviteDisplayName" @oninput="OnSearchInput" placeholder="Sök..." autocomplete="off" />
                        @if (_displayNameSuggestions.Any())
                        {
                            <div class="suggestions-dropdown" style="position:absolute;background:white;width:100%;z-index:10;border:1px solid #ccc">
                                @foreach (var sug in _displayNameSuggestions)
                                {
                                    <div style="padding:8px;cursor:pointer" @onclick="() => SelectSuggestion(sug)">@sug</div>
                                }
                            </div>
                        }
                    </div>
                </div>
                <button class="btn btn-primary btn-sm" @onclick="InviteAsync" disabled="@_inviting">Skicka</button>
            </div>
        }

        <div class="card">
            <div class="card-title"><span class="material-icons">workspace_premium</span> Prenumeration</div>
            <div class="kpi-card"><div class="kpi-label">Plan</div><div class="kpi-value">@SubscriptionLimits.TierLabel(BudgetState.Tier)</div></div>
        </div>

        <div class="card" style="border-left:3px solid var(--color-expense)">
            <div class="card-title" style="color:var(--color-expense)">Radera konto</div>
            <p style="font-size:.82rem">Detta raderar all din persondata permanent.</p>
            @if (_showDeleteConfirm)
            {
                <input class="form-control" @bind="_deleteConfirmText" placeholder="Skriv RADERA" />
                <button class="btn btn-danger btn-sm" @onclick="DeleteAccountAsync" disabled="@(_deleteConfirmText != "RADERA" || _deleting)">Bekräfta</button>
            }
            else
            {
                <button class="btn btn-outline-danger btn-sm" @onclick="() => _showDeleteConfirm = true">Radera mitt konto</button>
            }
        </div>
    </div>;
}