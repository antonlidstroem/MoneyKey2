@using MoneyKey.Core.DTOs.Lists
@using System.Text.Json
@inject ListApiService ListSvc
@inject ToastService Toast
@inject BudgetState BudgetState

<div class="decision-list">
    @if (!_alternatives.Any())
    {
        <div style="text-align:center;padding:20px;color:var(--color-muted);font-size:.875rem">
            Inga alternativ ännu.
        </div>
    }
    else
    {
        @* ── Winner indicator ──────────────────────────────────── *@
        @if (_alternatives.Count > 1)
        {
            var top = _alternatives.OrderByDescending(a => Score(a)).First();
            <div style="font-size:.75rem;color:var(--color-muted);margin-bottom:10px;
                padding:8px 12px;background:var(--color-bg);border-radius:8px">
                📊 Poängledare: <strong>@top.Name</strong> (@Score(top).ToString("N1") p)
                · Magkänsloledare: <strong>@_alternatives.OrderByDescending(a => a.GutFeeling).First().Name</strong>
            </div>
        }

        @* ── Alternatives ────────────────────────────────────── *@
        @foreach (var (alt, idx) in _alternatives.Select((a, i) => (a, i)))
        {
            var a = alt;
            var i = idx;
            var isTop = _alternatives.Count > 1 && Score(a) == _alternatives.Max(x => Score(x));

            <div class="decision-alt-card @(isTop ? "is-winner" : "")"
                 style="margin-bottom:10px">

                <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px">
                    @if (isTop)
                    {
                        <span title="Poängledare">🏆</span>
                    }
                    <strong style="flex:1;font-size:.9rem">@a.Name</strong>
                    <span style="font-size:.72rem;color:var(--color-muted)">
                        Poäng: @Score(a).ToString("N1")
                    </span>
                    @if (CanEdit)
                    {
                        <button class="btn btn-ghost btn-icon btn-sm"
                                @onclick="() => RemoveAlternativeAsync(i)">
                            <span class="material-icons" style="font-size:.8rem;
                            color:var(--color-expense)">close</span>
                        </button>
                    }
                </div>

                @* Gut feeling slider *@
                <div style="margin-bottom:10px">
                    <div style="display:flex;justify-content:space-between;
                        font-size:.7rem;color:var(--color-muted);margin-bottom:4px">
                        <span>😐 Tveksam</span>
                        <span style="font-weight:700;
                            color:@GutColor(a.GutFeeling)">
                            @GutLabel(a.GutFeeling)
                        </span>
                        <span>😍 Ja!</span>
                    </div>
                    <input type="range" min="0" max="100"
                           class="gut-slider-track"
                           value="@a.GutFeeling"
                           disabled="@(!CanEdit)"
                           @onchange="e => UpdateGutAsync(i, int.Parse(e.Value!.ToString()!))" />
                </div>

                @* Pros *@
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
                    <div>
                        <div style="font-size:.68rem;font-weight:700;color:#22c55e;
                            text-transform:uppercase;letter-spacing:.05em;margin-bottom:4px">
                            ✓ För
                        </div>
                        @foreach (var pro in a.Pros ?? new())
                        {
                            var p = pro;
                            <div style="font-size:.8rem;display:flex;align-items:flex-start;
                                gap:4px;margin-bottom:2px">
                                <span style="color:#22c55e;flex-shrink:0;margin-top:1px">+</span>
                                <span>@p</span>
                                @if (CanEdit)
                                {
                                    <button class="btn btn-ghost btn-icon btn-sm"
                                            style="padding:0;width:16px;height:16px;
                                        flex-shrink:0;margin-left:auto"
                                            @onclick="() => RemoveProAsync(i, p)">
                                        <span class="material-icons"
                                              style="font-size:.65rem">close</span>
                                    </button>
                                }
                            </div>
                        }
                        @if (CanEdit)
                        {
                            <input class="list-quick-add__input"
                                   style="font-size:.75rem;padding:4px 6px;margin-top:4px"
                                   placeholder="+ Lägg till fördel"
                                   @bind="_newPros[i]"
                                   @onkeydown="e => OnProKeyDown(e, i)" />
                        }
                    </div>

                    @* Cons *@
                    <div>
                        <div style="font-size:.68rem;font-weight:700;color:var(--color-expense);
                            text-transform:uppercase;letter-spacing:.05em;margin-bottom:4px">
                            ✗ Mot
                        </div>
                        @foreach (var con in a.Cons ?? new())
                        {
                            var c = con;
                            <div style="font-size:.8rem;display:flex;align-items:flex-start;
                                gap:4px;margin-bottom:2px">
                                <span style="color:var(--color-expense);flex-shrink:0;margin-top:1px">−</span>
                                <span>@c</span>
                                @if (CanEdit)
                                {
                                    <button class="btn btn-ghost btn-icon btn-sm"
                                            style="padding:0;width:16px;height:16px;
                                        flex-shrink:0;margin-left:auto"
                                            @onclick="() => RemoveConAsync(i, c)">
                                        <span class="material-icons"
                                              style="font-size:.65rem">close</span>
                                    </button>
                                }
                            </div>
                        }
                        @if (CanEdit)
                        {
                            <input class="list-quick-add__input"
                                   style="font-size:.75rem;padding:4px 6px;margin-top:4px"
                                   placeholder="− Lägg till nackdel"
                                   @bind="_newCons[i]"
                                   @onkeydown="e => OnConKeyDown(e, i)" />
                        }
                    </div>
                </div>

            </div>
        }
    }

    @* ── Add alternative ─────────────────────────────────────── *@
    @if (CanEdit)
    {
        <div class="list-quick-add" style="margin-top:8px">
            <input class="list-quick-add__input"
                   @bind="_newAltName"
                   placeholder="Lägg till alternativ..."
                   @onkeydown="OnAltKeyDownAsync" />
            <button class="btn btn-primary btn-sm"
                    disabled="@string.IsNullOrWhiteSpace(_newAltName)"
                    @onclick="AddAlternativeAsync">
                <span class="material-icons" style="font-size:.85rem">add</span>
            </button>
        </div>
    }

    @* ── Mark as decided ─────────────────────────────────────── *@
    @if (_alternatives.Count > 1 && CanEdit && !_decided)
    {
        <div style="margin-top:14px;padding-top:12px;border-top:1px solid var(--color-border)">
            <p style="font-size:.8rem;color:var(--color-muted);margin-bottom:8px">
                Redo att bestämma dig? Välj vilket alternativ du går med.
            </p>
            <div style="display:flex;gap:6px;flex-wrap:wrap">
                @foreach (var alt in _alternatives)
                {
                    var a = alt;
                    <button class="btn btn-secondary btn-sm" @onclick="() => DecideAsync(a)">
                        Välj: @a.Name
                    </button>
                }
            </div>
        </div>
    }
    @if (_decided)
    {
        <div style="margin-top:12px;padding:10px 14px;background:var(--color-income-bg);
            border-radius:8px;font-size:.85rem">
            ✅ Beslutat: <strong>@_decidedName</strong>
        </div>
    }
</div>

@code {
    [Parameter] public UserListDto List { get; set; } = null!;
    [Parameter] public bool CanEdit { get; set; }
    [Parameter] public EventCallback<UserListDto> OnUpdated { get; set; }

    private List<DecisionAlternative> _alternatives = new();
    private Dictionary<int, string> _newPros = new();
    private Dictionary<int, string> _newCons = new();
    private string _newAltName = "";
    private bool _decided;
    private string _decidedName = "";

    // Stored in the list's one "meta-item" (ItemData = JSON of all alternatives)
    private ListItemDto? _metaItem;

    protected override void OnParametersSet()
    {
        _metaItem = List.Items.FirstOrDefault();
        _alternatives = ParseAlternatives(_metaItem);
        _decided = _alternatives.Any(a => a.IsSelected);
        _decidedName = _alternatives.FirstOrDefault(a => a.IsSelected)?.Name ?? "";
        for (var i = 0; i < _alternatives.Count; i++)
        { _newPros.TryAdd(i, ""); _newCons.TryAdd(i, ""); }
    }

    private static List<DecisionAlternative> ParseAlternatives(ListItemDto? item)
    {
        if (item == null || string.IsNullOrEmpty(item.ItemData)) return new();
        try { return JsonSerializer.Deserialize<List<DecisionAlternative>>(item.ItemData) ?? new(); }
        catch { return new(); }
    }

    private async Task PersistAsync()
    {
        var json = JsonSerializer.Serialize(_alternatives);
        if (_metaItem == null)
        {
            // First save: create the meta-item
            var created = await ListSvc.AddItemAsync(
                BudgetState.ActiveBudgetId, List.Id,
                new CreateListItemDto("[decision-data]") { ItemData = json });
            if (created != null)
            {
                _metaItem = created;
                List.Items.Clear();
                List.Items.Add(created);
            }
        }
        else
        {
            _metaItem.ItemData = json;
            await ListSvc.UpdateItemDataAsync(
                BudgetState.ActiveBudgetId, List.Id, _metaItem.Id, json);
        }
        await OnUpdated.InvokeAsync(List);
        StateHasChanged();
    }

    private async Task AddAlternativeAsync()
    {
        if (string.IsNullOrWhiteSpace(_newAltName)) return;
        _alternatives.Add(new DecisionAlternative(
            _newAltName.Trim(), new(), new(), 50, false));
        var idx = _alternatives.Count - 1;
        _newPros[idx] = ""; _newCons[idx] = "";
        _newAltName = "";
        await PersistAsync();
    }

    private async Task OnAltKeyDownAsync(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await AddAlternativeAsync();
    }

    private async Task RemoveAlternativeAsync(int idx)
    {
        _alternatives.RemoveAt(idx);
        await PersistAsync();
    }

    private async Task UpdateGutAsync(int idx, int value)
    {
        _alternatives[idx] = _alternatives[idx] with { GutFeeling = value };
        await PersistAsync();
    }

    private async Task RemoveProAsync(int idx, string pro)
    {
        var list = new List<string>(_alternatives[idx].Pros ?? new());
        list.Remove(pro);
        _alternatives[idx] = _alternatives[idx] with { Pros = list };
        await PersistAsync();
    }

    private async Task RemoveConAsync(int idx, string con)
    {
        var list = new List<string>(_alternatives[idx].Cons ?? new());
        list.Remove(con);
        _alternatives[idx] = _alternatives[idx] with { Cons = list };
        await PersistAsync();
    }

    private async Task OnProKeyDown(KeyboardEventArgs e, int idx)
    {
        if (e.Key != "Enter" || string.IsNullOrWhiteSpace(_newPros[idx])) return;
        var list = new List<string>(_alternatives[idx].Pros ?? new()) { _newPros[idx].Trim() };
        _alternatives[idx] = _alternatives[idx] with { Pros = list };
        _newPros[idx] = "";
        await PersistAsync();
    }

    private async Task OnConKeyDown(KeyboardEventArgs e, int idx)
    {
        if (e.Key != "Enter" || string.IsNullOrWhiteSpace(_newCons[idx])) return;
        var list = new List<string>(_alternatives[idx].Cons ?? new()) { _newCons[idx].Trim() };
        _alternatives[idx] = _alternatives[idx] with { Cons = list };
        _newCons[idx] = "";
        await PersistAsync();
    }

    private async Task DecideAsync(DecisionAlternative winner)
    {
        _alternatives = _alternatives
            .Select(a => a with { IsSelected = a.Name == winner.Name })
            .ToList();
        _decided = true;
        _decidedName = winner.Name;
        await PersistAsync();
    }

    // ── Scoring ───────────────────────────────────────────────────────────────

    private static double Score(DecisionAlternative a)
    {
        var prosScore = (a.Pros?.Count ?? 0) * 1.0;
        var consScore = (a.Cons?.Count ?? 0) * 1.0;
        var gut = a.GutFeeling / 100.0;
        return (prosScore - consScore) * 0.5 + gut * 1.5;
    }

    private static string GutLabel(int v) => v switch
    {
        < 25 => "Tveksam",
        < 45 => "Kanske",
        < 60 => "Neutral",
        < 75 => "Ganska bra",
        < 88 => "Bra känsla!",
        _ => "Starkt ja!"
    };

    private static string GutColor(int v) => v switch
    {
        < 35 => "var(--color-expense)",
        < 55 => "var(--color-muted)",
        < 75 => "#f59e0b",
        _ => "#22c55e"
    };
}