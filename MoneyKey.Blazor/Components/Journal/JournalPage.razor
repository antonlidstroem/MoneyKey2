    private static string TypeLabel(JournalEntryType t) => t switch
    {
        JournalEntryType.Transaction => "Transaktioner",
        JournalEntryType.Milersattning => "Milersättning",
        JournalEntryType.Vab => "VAB",
        JournalEntryType.ReceiptBatch => "Kvitton",
        JournalEntryType.List => "Listor",
        JournalEntryType.TimeEntry => "Tidposter",
        _ => t.ToString()
    };

    private static string TypeBadge(JournalEntryType t) => t switch
    {
        JournalEntryType.Transaction => "badge-primary",
        JournalEntryType.Milersattning => "badge-income",
        JournalEntryType.Vab => "badge-income",
        JournalEntryType.ReceiptBatch => "badge",
        JournalEntryType.TimeEntry => "badge-muted",
        _ => "badge-muted"
    };

    private static string StatusBadge(string s) => s switch
    {
        "Godkänd" => "badge-income",
        "Avslagen" => "badge-expense",
        "Utbetald" => "badge-primary",
        _ => "badge-muted"
    };

    private static string AmountStr(JournalEntryDto e) =>
        e.EntryType == JournalEntryType.ReceiptBatch
            ? $"{e.Amount:N0} kr"
            : (e.Amount >= 0 ? "+" : "") + $"{e.Amount:N0} kr";
}