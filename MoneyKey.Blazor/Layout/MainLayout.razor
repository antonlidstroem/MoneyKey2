@inherits LayoutComponentBase
@inject BudgetState BudgetState
@inject AuthService AuthSvc
@inject BudgetService BudgetSvc
@inject SignalRService SignalR
@inject NavigationManager Nav
@inject IConfiguration Config
@inject HttpClient Http
@using MoneyKey.Blazor.Components.Shared
@using Microsoft.AspNetCore.Components.Authorization

<div class="app-shell">
    <aside class="sidebar">
        <div class="sidebar-logo"><h1>Money<span>Key</span></h1></div>

        <div class="budget-switcher">
            <select @onchange="OnBudgetChanged" value="@BudgetState.ActiveBudgetId">
                @if (!BudgetState.MyBudgets.Any())
                {
                    <option disabled selected>Inga budgetar...</option>
                }
                else
                {
                    @foreach (var b in BudgetState.MyBudgets)
                    {
                        <option value="@b.Id">@b.Name</option>
                    }
                }
            </select>
        </div>

        <nav class="nav-section">
            <div class="nav-label">Navigering</div>
            <NavLink class="nav-item" href="/" Match="NavLinkMatch.All">
                <span class="material-icons">list_alt</span> Journal
            </NavLink>
            <NavLink class="nav-item" href="/projects">
                <span class="material-icons">folder</span> Projekt
            </NavLink>
            @if (BudgetState.IsFeatureEnabled("Milersattning"))
            {
                <NavLink class="nav-item" href="/milersattning">
                    <span class="material-icons">directions_car</span> Milersättning
                </NavLink>
            }
            @if (BudgetState.IsFeatureEnabled("Vab"))
            {
                <NavLink class="nav-item" href="/vab">
                    <span class="material-icons">child_care</span> VAB
                </NavLink>
            }
            @if (BudgetState.IsFeatureEnabled("Receipts"))
            {
                <NavLink class="nav-item" href="/receipts">
                    <span class="material-icons">receipt_long</span> Kvittounderlag
                </NavLink>
            }
        </nav>

        <nav class="nav-section">
            <div class="nav-label">Rapporter</div>
            <NavLink class="nav-item" href="/dashboard">
                <span class="material-icons">dashboard</span> Dashboard
            </NavLink>
            <NavLink class="nav-item" href="/reports">
                <span class="material-icons">bar_chart</span> Export &amp; Import
            </NavLink>
            @if (BudgetState.IsOwner)
            {
                <NavLink class="nav-item" href="/settings">
                    <span class="material-icons">settings</span> Inställningar
                </NavLink>
            }
        </nav>

        <div class="sidebar-footer">
            <div class="user-chip">
                <div class="user-avatar">@Initials</div>
                <div>
                    <div class="user-name">@(AuthSvc.CurrentUser?.Email ?? "Gäst")</div>
                    <button class="btn btn-ghost btn-sm" @onclick="LogoutAsync">Logga ut</button>
                </div>
            </div>
        </div>
    </aside>

    <div class="main-area">
        @Body
    </div>
</div>

<nav class="mobile-bottom-nav">
    <NavLink class="mobile-nav-tab" href="/" Match="NavLinkMatch.All">
        <span class="material-icons">list_alt</span>
        <span>Journal</span>
    </NavLink>
    <NavLink class="mobile-nav-tab" href="/projects">
        <span class="material-icons">folder</span>
        <span>Projekt</span>
    </NavLink>
    <NavLink class="mobile-nav-tab" href="/receipts">
        <span class="material-icons">receipt_long</span>
        <span>Kvitton</span>
    </NavLink>
    <button class="mobile-nav-tab" @onclick='() => _morOpen = true'>
        <span class="material-icons">more_horiz</span>
        <span>Mer</span>
    </button>
</nav>

@if (_morOpen)
{
    <div class="sheet-overlay" @onclick='() => _morOpen = false'>
        <div class="sheet-container" @onclick:stopPropagation style="max-height:90%">
            <div class="sheet-handle-bar"></div>
            <div style="display:flex;align-items:center;gap:12px;padding:14px 16px;border-bottom:.5px solid var(--color-border)">
                <div class="user-avatar" style="width:40px;height:40px;font-size:.9rem;flex-shrink:0">@Initials</div>
                <div>
                    <div style="font-weight:500;font-size:.9rem">@AuthSvc.CurrentUser?.FirstName @AuthSvc.CurrentUser?.LastName</div>
                    <div style="font-size:.78rem;color:var(--color-muted)">@(AuthSvc.CurrentUser?.Email ?? "")</div>
                </div>
            </div>
            @if (BudgetState.MyBudgets.Count > 1)
            {
                <div style="padding:12px 16px;border-bottom:.5px solid var(--color-border)">
                    <div style="font-size:.7rem;font-weight:600;color:var(--color-muted);text-transform:uppercase;margin-bottom:6px">Aktiv budget</div>
                    <select class="form-control" @onchange="OnBudgetChanged" value="@BudgetState.ActiveBudgetId">
                        @foreach (var b in BudgetState.MyBudgets) { <option value="@b.Id">@b.Name</option> }
                    </select>
                </div>
            }
            <a class="more-nav-item" href="/milersattning" @onclick='() => _morOpen = false'><span class="material-icons">directions_car</span> Milersättning</a>
            <a class="more-nav-item" href="/vab"          @onclick='() => _morOpen = false'><span class="material-icons">child_care</span> VAB</a>
            <a class="more-nav-item" href="/dashboard"    @onclick='() => _morOpen = false'><span class="material-icons">dashboard</span> Dashboard</a>
            <a class="more-nav-item" href="/reports"      @onclick='() => _morOpen = false'><span class="material-icons">bar_chart</span> Export &amp; Import</a>
            @if (BudgetState.IsOwner)
            {
                <a class="more-nav-item" href="/settings" @onclick='() => _morOpen = false'><span class="material-icons">settings</span> Inställningar</a>
            }
            <div style="padding:16px">
                <button class="btn btn-secondary" style="width:100%;justify-content:center" @onclick="MobileLogoutAsync">
                    <span class="material-icons" style="font-size:.9rem">logout</span> Logga ut
                </button>
            </div>
        </div>
    </div>
}

<ToastContainer />

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthStateTask { get; set; }
    [Inject] private AuthenticationStateProvider AuthProvider { get; set; } = null!;

    private bool _morOpen;

    private string Initials => AuthSvc.CurrentUser is { } u
        ? $"{u.FirstName?.FirstOrDefault()}{u.LastName?.FirstOrDefault()}".ToUpper()
        : "?";

    protected override async Task OnInitializedAsync()
    {
        if (AuthStateTask != null)
        {
            var authState = await AuthStateTask;
            if (authState.User.Identity is { IsAuthenticated: true })
            {
                try
                {
                    var budgets = await BudgetSvc.GetMyBudgetsAsync();
                    if (budgets != null) BudgetState.SetBudgets(budgets);

                    var token = JwtAuthenticationStateProvider.AccessToken;
                    if (!string.IsNullOrEmpty(token))
                    {
                        // Load feature flags for the active budget
                    var disabled = await BudgetSvc.GetDisabledFeaturesAsync(BudgetState.ActiveBudgetId) ?? new();
                    BudgetState.SetFeatures(disabled);

                    var apiBase = Config["ApiBaseUrl"] ?? "https://localhost:7000";
                        await SignalR.ConnectAsync(apiBase, token, BudgetState.ActiveBudgetId, Http, AuthProvider);
                    }
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"Fel vid initiering av MainLayout: {ex.Message}");
                }
            }
        }
    }

    private async Task OnBudgetChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var id))
        {
            var b = BudgetState.MyBudgets.FirstOrDefault(x => x.Id == id);
            if (b != null)
            {
                BudgetState.SetActiveBudget(b);
                await SignalR.SwitchBudgetAsync(id);
                _morOpen = false;
                Nav.NavigateTo("/");
            }
        }
    }

    private async Task LogoutAsync()       { await AuthSvc.LogoutAsync(); Nav.NavigateTo("/login"); }
    private async Task MobileLogoutAsync() { _morOpen = false; await AuthSvc.LogoutAsync(); Nav.NavigateTo("/login"); }
}
