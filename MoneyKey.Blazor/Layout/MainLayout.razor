@inherits LayoutComponentBase
@inject BudgetState BudgetState
@inject AuthService AuthSvc
@inject BudgetService BudgetSvc
@inject SignalRService SignalR
@inject NavigationManager Nav
@inject IConfiguration Config
@inject HttpClient Http
@inject SubscriptionApiService SubSvc
@inject InvitationApiService InvSvc
@using MoneyKey.Blazor.Components.Shared
@using Microsoft.AspNetCore.Components.Authorization
@using MoneyKey.Domain.Constants

<div class="app-shell">
    <aside class="sidebar">
        <div class="sidebar-logo"><h1>Money<span>Key</span></h1></div>

        <div class="budget-switcher">
            <select @onchange="OnBudgetChanged" value="@BudgetState.ActiveBudgetId">
                @if (!BudgetState.MyBudgets.Any()) { <option disabled selected>Inga budgetar...</option> }
                else { @foreach (var b in BudgetState.MyBudgets) { <option value="@b.Id">@b.Name</option> } }
            </select>
        </div>

        <nav class="nav-section">
            <div class="nav-label">Navigering</div>

            @* ── Timer widget ─────────────────────────────────────── *@
            @if (BudgetState.IsTimerRunning)
            {
                <div class="timer-widget" style="background:var(--color-income-bg);border:1px solid var(--color-income);border-radius:10px;padding:10px 12px;margin-bottom:8px;font-size:.82rem">
                    <div style="color:var(--color-income);font-weight:600;margin-bottom:4px">
                        <span class="material-icons" style="font-size:.9rem;vertical-align:middle;animation:pulse 1s infinite">timer</span>
                        Timer pågår
                    </div>
                    <div style="color:var(--color-muted)">@BudgetState.TimerJobName</div>
                    <button class="btn btn-primary btn-sm" style="width:100%;margin-top:6px" @onclick="StopTimerAsync">
                        <span class="material-icons" style="font-size:.85rem">stop</span> Stoppa
                    </button>
                </div>
            }

            @* ── Invitation badge ─────────────────────────────────── *@
            @if (BudgetState.PendingInvitations > 0)
            {
                <a class="nav-item" href="/invitations" style="background:rgba(249,168,37,.12);color:#F9A825;border-left:3px solid #F9A825">
                    <span class="material-icons">mail</span>
                    Inbjudningar
                    <span style="background:#F9A825;color:#000;border-radius:10px;padding:1px 7px;font-size:.7rem;font-weight:700;margin-left:auto">@BudgetState.PendingInvitations</span>
                </a>
            }

            <NavLink class="nav-item" href="/" Match="NavLinkMatch.All">
                <span class="material-icons">list_alt</span> Journal
            </NavLink>
            <NavLink class="nav-item" href="/projects">
                <span class="material-icons">folder</span> Projekt
            </NavLink>
            @if (BudgetState.IsFeatureEnabled("Milersattning"))
            {
                <NavLink class="nav-item" href="/milersattning">
                    <span class="material-icons">directions_car</span> Milersättning
                </NavLink>
            }
            @if (BudgetState.IsFeatureEnabled("Vab"))
            {
                <NavLink class="nav-item" href="/vab">
                    <span class="material-icons">child_care</span> VAB
                </NavLink>
            }
            @if (BudgetState.IsFeatureEnabled("Lists"))
            {
                <NavLink class="nav-item" href="/lists">
                    <span class="material-icons">checklist</span> Listor
                </NavLink>
            }
            @if (BudgetState.IsFeatureEnabled("TimeTracking"))
            {
                <NavLink class="nav-item" href="/timetracking">
                    <span class="material-icons">schedule</span> Tidrapport
                </NavLink>
                <NavLink class="nav-item" href="/jobs">
                    <span class="material-icons">work</span> Inkomstkällor
                </NavLink>
            }
            @if (BudgetState.IsFeatureEnabled("Receipts"))
            {
                <NavLink class="nav-item" href="/receipts">
                    <span class="material-icons">receipt_long</span> Kvittounderlag
                </NavLink>
            }
        </nav>

        <nav class="nav-section">
            <div class="nav-label">Rapporter</div>
            <NavLink class="nav-item" href="/dashboard"><span class="material-icons">dashboard</span> Dashboard</NavLink>
            <NavLink class="nav-item" href="/reports"><span class="material-icons">bar_chart</span> Export &amp; Import</NavLink>
            @if (BudgetState.IsOwner)
            {
                <NavLink class="nav-item" href="/settings"><span class="material-icons">settings</span> Inställningar</NavLink>
            }
            @if (BudgetState.IsSystemAdmin)
            {
                <NavLink class="nav-item" href="/admin" style="color:var(--color-expense)">
                    <span class="material-icons">admin_panel_settings</span> Admin
                </NavLink>
            }
        </nav>

        <div class="sidebar-footer">
            <div class="user-chip">
                <div class="user-avatar">@Initials</div>
                <div style="min-width:0">
                    @if (!string.IsNullOrEmpty(BudgetState.DisplayName))
                    {
                        <div class="user-name" style="font-weight:600">@BudgetState.DisplayName</div>
                        <div style="font-size:.72rem;color:var(--color-muted);overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
                            @SubscriptionLimits.TierLabel(BudgetState.Tier)
                        </div>
                    }
                    else
                    {
                        <div class="user-name">@(AuthSvc.CurrentUser?.Email ?? "Gäst")</div>
                    }
                    <button class="btn btn-ghost btn-sm" @onclick="LogoutAsync">Logga ut</button>
                </div>
            </div>
        </div>
    </aside>

    <div class="main-area">@Body</div>
</div>

<!-- Mobile bottom nav -->
<nav class="mobile-bottom-nav">
    <NavLink class="mobile-nav-tab" href="/" Match="NavLinkMatch.All">
        <span class="material-icons">list_alt</span><span>Journal</span>
    </NavLink>
    <NavLink class="mobile-nav-tab" href="/projects">
        <span class="material-icons">folder</span><span>Projekt</span>
    </NavLink>
    <NavLink class="mobile-nav-tab" href="/dashboard">
        <span class="material-icons">dashboard</span><span>Dashboard</span>
    </NavLink>
    <button class="mobile-nav-tab" @onclick='() => _morOpen = true' style="position:relative">
        <span class="material-icons">more_horiz</span>
        <span>Mer</span>
        @if (BudgetState.PendingInvitations > 0)
        {
            <span style="position:absolute;top:6px;right:10px;background:#F9A825;color:#000;border-radius:50%;width:16px;height:16px;font-size:.6rem;font-weight:700;display:flex;align-items:center;justify-content:center">@BudgetState.PendingInvitations</span>
        }
    </button>
</nav>

@if (_morOpen)
{
    <div class="sheet-overlay" @onclick='() => _morOpen = false'>
        <div class="sheet-container" @onclick:stopPropagation style="max-height:90%;overflow-y:auto">
            <div class="sheet-handle-bar"></div>
            <div style="display:flex;align-items:center;gap:12px;padding:14px 16px;border-bottom:.5px solid var(--color-border)">
                <div class="user-avatar" style="width:40px;height:40px;font-size:.9rem;flex-shrink:0">@Initials</div>
                <div style="min-width:0">
                    <div style="font-weight:600;font-size:.92rem">@(BudgetState.DisplayName.Length > 0 ? BudgetState.DisplayName : $"{AuthSvc.CurrentUser?.FirstName} {AuthSvc.CurrentUser?.LastName}")</div>
                    <div style="font-size:.75rem;color:var(--color-muted)">@SubscriptionLimits.TierLabel(BudgetState.Tier)</div>
                </div>
            </div>
            @if (BudgetState.MyBudgets.Count > 1)
            {
                <div style="padding:12px 16px;border-bottom:.5px solid var(--color-border)">
                    <div style="font-size:.7rem;font-weight:600;color:var(--color-muted);text-transform:uppercase;margin-bottom:6px">Aktiv budget</div>
                    <select class="form-control" @onchange="OnBudgetChanged" value="@BudgetState.ActiveBudgetId">
                        @foreach (var b in BudgetState.MyBudgets) { <option value="@b.Id">@b.Name</option> }
                    </select>
                </div>
            }
            @if (BudgetState.PendingInvitations > 0)
            {
                <a class="more-nav-item" href="/invitations" @onclick='() => _morOpen = false' style="color:#F9A825">
                    <span class="material-icons">mail</span> Inbjudningar (@BudgetState.PendingInvitations)
                </a>
            }
            <a class="more-nav-item" href="/milersattning" @onclick='() => _morOpen = false'><span class="material-icons">directions_car</span> Milersättning</a>
            <a class="more-nav-item" href="/vab"           @onclick='() => _morOpen = false'><span class="material-icons">child_care</span> VAB</a>
            <a class="more-nav-item" href="/lists"         @onclick='() => _morOpen = false'><span class="material-icons">checklist</span> Listor</a>
            <a class="more-nav-item" href="/timetracking"  @onclick='() => _morOpen = false'><span class="material-icons">schedule</span> Tidrapportering</a>
            <a class="more-nav-item" href="/receipts"      @onclick='() => _morOpen = false'><span class="material-icons">receipt_long</span> Kvittounderlag</a>
            <a class="more-nav-item" href="/reports"       @onclick='() => _morOpen = false'><span class="material-icons">bar_chart</span> Export &amp; Import</a>
            @if (BudgetState.IsOwner)
            { <a class="more-nav-item" href="/settings" @onclick='() => _morOpen = false'><span class="material-icons">settings</span> Inställningar</a> }
            @if (BudgetState.IsSystemAdmin)
            { <a class="more-nav-item" href="/admin" @onclick='() => _morOpen = false' style="color:var(--color-expense)"><span class="material-icons">admin_panel_settings</span> Admin</a> }
            <div style="padding:16px">
                <button class="btn btn-secondary" style="width:100%;justify-content:center" @onclick="MobileLogoutAsync">
                    <span class="material-icons" style="font-size:.9rem">logout</span> Logga ut
                </button>
            </div>
        </div>
    </div>
}

<ToastContainer />

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthStateTask { get; set; }
    [Inject] private AuthenticationStateProvider AuthProvider { get; set; } = null!;

    private bool _morOpen;

    private string Initials => !string.IsNullOrEmpty(BudgetState.DisplayName)
        ? BudgetState.DisplayName[..Math.Min(2, BudgetState.DisplayName.Length)].ToUpper()
        : AuthSvc.CurrentUser is { } u
            ? $"{u.FirstName?.FirstOrDefault()}{u.LastName?.FirstOrDefault()}".ToUpper()
            : "?";

    protected override async Task OnInitializedAsync()
    {
        if (AuthStateTask == null) return;
        var authState = await AuthStateTask;
        if (authState.User.Identity is not { IsAuthenticated: true }) return;

        try
        {
            // Load budgets
            var budgets = await BudgetSvc.GetMyBudgetsAsync();
            if (budgets != null) BudgetState.SetBudgets(budgets);

            // Load subscription info (DisplayName, tier, limits)
            var sub = await SubSvc.GetMineAsync();
            if (sub != null) BudgetState.SetSubscription(sub);

            // Load feature flags
            var disabled = await BudgetSvc.GetDisabledFeaturesAsync(BudgetState.ActiveBudgetId) ?? new();
            BudgetState.SetFeatures(disabled);

            // Load pending invitations count
            var invitations = await InvSvc.GetPendingAsync();
            BudgetState.SetPendingInvitations(invitations?.Count ?? 0);

            // Connect SignalR
            var token = JwtAuthenticationStateProvider.AccessToken;
            if (!string.IsNullOrEmpty(token))
            {
                var apiBase = Config["ApiBaseUrl"] ?? "https://localhost:7000";
                await SignalR.ConnectAsync(apiBase, token, BudgetState.ActiveBudgetId, Http, AuthProvider);
            }
        }
        catch (Exception ex) { Console.WriteLine($"MainLayout init error: {ex.Message}"); }
    }

    private async Task OnBudgetChanged(ChangeEventArgs e)
    {
        if (!int.TryParse(e.Value?.ToString(), out var id)) return;
        var b = BudgetState.MyBudgets.FirstOrDefault(x => x.Id == id);
        if (b == null) return;
        BudgetState.SetActiveBudget(b);
        var disabled = await BudgetSvc.GetDisabledFeaturesAsync(id) ?? new();
        BudgetState.SetFeatures(disabled);
        await SignalR.SwitchBudgetAsync(id);
        _morOpen = false;
        Nav.NavigateTo("/");
    }

    private async Task StopTimerAsync()
    {
        var (minutes, jobId, _, _) = BudgetState.StopTimer();
        Nav.NavigateTo($"/timetracking?stopMinutes={minutes}&jobId={jobId}");
    }

    private async Task LogoutAsync()       { await AuthSvc.LogoutAsync(); Nav.NavigateTo("/login"); }
    private async Task MobileLogoutAsync() { _morOpen = false; await AuthSvc.LogoutAsync(); Nav.NavigateTo("/login"); }
}
